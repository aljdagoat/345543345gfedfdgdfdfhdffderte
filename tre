        local cardG = create("UIGradient",{
            Parent=cardH, Rotation=90,
            Color=ColorSequence.new{
                ColorSequenceKeypoint.new(0,themes.preset.low_contrast),
                ColorSequenceKeypoint.new(1,themes.preset.high_contrast),
            }})
        applyTheme(cardG,"contrast","Color")
        local tb = create("TextBox",{
            Parent=cardH, FontFace=customFont,
            TextColor3=themes.preset.text, Text="",
            PlaceholderText=placeholder,
            PlaceholderColor3=rgb(100,100,100),
            BackgroundTransparency=1,
            Size=dim2(1,-8,1,0), Position=dim2(0,4,0,0),
            TextSize=12, ClearTextOnFocus=false,
            TextXAlignment=Enum.TextXAlignment.Left,
            BorderSizePixel=0, BackgroundColor3=rgb(255,255,255),
        })
        return cardOut, tb
    end

    -- ── Section: Save ─────────────────────────────────────────────────────────
    local saveSection = _makeSection(container, "Save Config", 1)
    local _, saveTB = makeInputRow(saveSection, "Config name...", 1)
    local saveHolder = _makeButtonHolder(saveSection, 2)
    local saveStatus = makeStatusLabel(saveSection, 3)

    _makeButton(saveHolder, "Save", function()
        local name = saveTB.Text:gsub("%s+","_")
        if name == "" then
            saveStatus.Text = "Enter a config name first"
            tween(saveStatus,{TextColor3=themes.preset.accent})
            return
        end
        local ok, err = pcall(function() winRef:saveConfig(name) end)
        if ok then
            saveStatus.Text = "Saved: "..name..".json"
            tween(saveStatus,{TextColor3=themes.preset.accent})
        else
            saveStatus.Text = "Save failed"
            tween(saveStatus,{TextColor3=rgb(200,50,50)})
            warn("[UILib] saveConfig error:", err)
        end
        task.delay(3, function()
            if saveStatus and saveStatus.Parent then saveStatus.Text="" end
        end)
    end)

    -- ── Section: Load ─────────────────────────────────────────────────────────
    local loadSection = _makeSection(container, "Load Config", 2)
    local _, loadTB = makeInputRow(loadSection, "Config name...", 1)
    local loadHolder = _makeButtonHolder(loadSection, 2)
    local loadStatus = makeStatusLabel(loadSection, 3)

    _makeButton(loadHolder, "Load", function()
        local name = loadTB.Text:gsub("%s+","_")
        if name == "" then
            loadStatus.Text = "Enter a config name first"
            tween(loadStatus,{TextColor3=themes.preset.accent})
            return
        end
        local ok, result = pcall(function() return winRef:loadConfig(name) end)
        if ok and result then
            loadStatus.Text = "Loaded: "..name..".json"
            tween(loadStatus,{TextColor3=themes.preset.accent})
        elseif ok and not result then
            loadStatus.Text = "Config not found"
            tween(loadStatus,{TextColor3=rgb(200,100,50)})
        else
            loadStatus.Text = "Load failed"
            tween(loadStatus,{TextColor3=rgb(200,50,50)})
            warn("[UILib] loadConfig error:", result)
        end
        task.delay(3, function()
            if loadStatus and loadStatus.Parent then loadStatus.Text="" end
        end)
    end)

    -- ── Section: Saved Configs ────────────────────────────────────────────────
    local listSection = _makeSection(container, "Saved Configs", 3)
    local refreshHolder = _makeButtonHolder(listSection, 1)

    -- The saved-configs list refreshes on demand
    local listContainer = create("Frame",{
        Parent=listSection, Name="config_list",
        Size=dim2(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundTransparency=1, BorderSizePixel=0, LayoutOrder=2,
    })
    create("UIListLayout",{
        Parent=listContainer, Padding=dim(0,3),
        SortOrder=Enum.SortOrder.LayoutOrder,
    })

    local function refreshList()
        for _,c in ipairs(listContainer:GetChildren()) do
            if not c:IsA("UIListLayout") then c:Destroy() end
        end
        local ok, files = pcall(listfiles, "configs")
        if not ok or not files then return end
        for idx, path in ipairs(files) do
            local name = path:match("([^/\\]+)%.json$")
            if name then
                local rowHolder = _makeButtonHolder(listContainer, idx)
                _makeButton(rowHolder, name, function()
                    loadTB.Text = name
                end)
            end
        end
    end
    refreshList()

    _makeButton(refreshHolder, "Refresh List", function()
        refreshList()
    end)

    return content
end

