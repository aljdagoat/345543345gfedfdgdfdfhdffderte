        Position = dim2(0, 0, 0, 0), Size = dim2(1, -70, 1, 0),
        TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left
    })

    -- Key badge: outline → inline → holder
    local badgeOutline = create("Frame", {
        Parent = cardHolder,
        AnchorPoint = vec2(1, 0.5),
        Position = dim2(1, 0, 0.5, 0),
        Size = dim2(0, 66, 0, 16),
        BackgroundColor3 = themes.preset.outline, BorderSizePixel = 0
    })
    applyTheme(badgeOutline, "outline", "BackgroundColor3")

    local badgeInline = create("Frame", {
        Parent = badgeOutline, Position = dim2(0, 1, 0, 1),
        Size = dim2(1, -2, 1, -2), BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.inline
    })
    applyTheme(badgeInline, "inline", "BackgroundColor3")

    local badgeHolder = create("Frame", {
        Parent = badgeInline, Position = dim2(0, 1, 0, 1),
        Size = dim2(1, -2, 1, -2), BorderSizePixel = 0,
        BackgroundColor3 = rgb(255, 255, 255)
    })
    local badgeGrad = create("UIGradient", {
        Parent = badgeHolder, Rotation = 90,
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1, themes.preset.high_contrast)
        }
    })
    applyTheme(badgeGrad, "contrast", "Color")

    local badgeText = create("TextButton", {
        Parent = badgeHolder, FontFace = customFont,
        Text = defaultKey.Name, TextColor3 = themes.preset.accent,
        BackgroundTransparency = 1, Size = dim2(1, 0, 1, 0),
        TextSize = 10, AutoButtonColor = false,
        TextXAlignment = Enum.TextXAlignment.Center
    })
    applyTheme(badgeText, "accent", "TextColor3")

    -- Listening pulse overlay
    local listeningOverlay = create("Frame", {
        Parent = badgeHolder, Size = dim2(1, 0, 1, 0),
        BackgroundColor3 = themes.preset.accent,
        BackgroundTransparency = 1, BorderSizePixel = 0, ZIndex = 5
    })
    applyTheme(listeningOverlay, "accent", "BackgroundColor3")

    local currentKey = defaultKey
    local listening = false

    badgeText.MouseButton1Click:Connect(function()
        if listening then return end
        listening = true
        badgeText.Text = "..."
        badgeText.TextColor3 = themes.preset.text
        tween(listeningOverlay, { BackgroundTransparency = 0.82 })
        local c
        c = UserInputService.InputBegan:Connect(function(input, processed)
            if processed then return end
            if input.UserInputType == Enum.UserInputType.Keyboard then
                currentKey = input.KeyCode
                badgeText.Text = input.KeyCode.Name
                tween(badgeText,        { TextColor3 = themes.preset.accent })
                tween(listeningOverlay, { BackgroundTransparency = 1 })
                listening = false
                c:Disconnect()
                if callback then callback(currentKey) end
            end
        end)
    end)

    -- Hover overlay on badge (white fade, no gradient conflict)
    local badgeHoverOverlay = Instance.new("Frame")
    badgeHoverOverlay.Size = dim2(1, 0, 1, 0)
    badgeHoverOverlay.BackgroundColor3 = rgb(255, 255, 255)
    badgeHoverOverlay.BackgroundTransparency = 1
    badgeHoverOverlay.BorderSizePixel = 0
    badgeHoverOverlay.ZIndex = 6
    badgeHoverOverlay.Parent = badgeHolder

    badgeText.MouseEnter:Connect(function()
        tween(badgeHoverOverlay, { BackgroundTransparency = 0.88 })
    end)
    badgeText.MouseLeave:Connect(function()
        if not listening then
            tween(badgeHoverOverlay, { BackgroundTransparency = 1 })
        end
    end)

    return cardOutline, function() return currentKey end
end

