        AutomaticSize=Enum.AutomaticSize.Y,
        TextYAlignment=Enum.TextYAlignment.Top,
        TextSize=12, BackgroundColor3=rgb(255,255,255),
        LayoutOrder=order or 0,
    })

    -- label row
    local leftComp = create("Frame",{
        Parent=root, Name="left_components",
        BackgroundTransparency=1,
        Position=dim2(0,2,0,-1),
        Size=dim2(0,0,0,14), BorderSizePixel=0,
        BackgroundColor3=rgb(255,255,255),
    })
    create("UIListLayout",{
        Parent=leftComp, Padding=dim(0,5),
        FillDirection=Enum.FillDirection.Horizontal,
    })
    create("TextLabel",{
        Parent=leftComp, FontFace=customFont,
        Text=label, TextColor3=themes.preset.text,
        BackgroundTransparency=1, Size=dim2(0,0,1,-1),
        AutomaticSize=Enum.AutomaticSize.X,
        BorderSizePixel=0, TextSize=12,
        BackgroundColor3=rgb(255,255,255),
    })

    -- bottom: the clickable dropdown bar
    local bottomComp = create("Frame",{
        Parent=root, Name="bottom_components",
        Position=dim2(0,0,0,15),
        Size=dim2(1,26,0,0), BorderSizePixel=0,
        BackgroundColor3=rgb(255,255,255),
    })
    -- NOTE: UIListLayout added AFTER children (matches Skibid order)

    local dropBtn = create("TextButton",{
        Parent=bottomComp,
        Position=dim2(0,0,0,2),
        Size=dim2(1,-27,1,18),
        BorderSizePixel=0,
        BackgroundColor3=themes.preset.outline,
        Text="", AutoButtonColor=false,
    })
    applyTheme(dropBtn,"outline","BackgroundColor3")

    -- Skibid: hoverify(dropdown_REAL, dropdown) → hover frame parented to dropdown, triggered by dropdown_REAL
    local dropHover = create("Frame",{
        Parent=dropBtn,
        BackgroundTransparency=1,
        Size=dim2(1,0,1,0),
        BorderSizePixel=0,
        BackgroundColor3=themes.preset.accent,
        ZIndex=1,
    })
    applyTheme(dropHover,"accent","BackgroundColor3")

    local dropIn = create("Frame",{
        Parent=dropBtn, Name="inline",
        ZIndex=2, Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
        BorderSizePixel=0,
        BackgroundColor3=themes.preset.inline,
    })
    applyTheme(dropIn,"inline","BackgroundColor3")

    local dropBg = create("Frame",{
        Parent=dropIn, Name="background",
        Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
        ZIndex=2, BorderSizePixel=0,
        BackgroundTransparency=1,  -- Skibid: BackgroundTransparency=1 on accent frame
        BackgroundColor3=themes.preset.accent,
    })
    applyTheme(dropBg,"accent","BackgroundColor3")
    -- Skibid: background has its own gradient
    create("UIGradient",{
        Parent=dropBg, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,rgb(255,255,255)),
            ColorSequenceKeypoint.new(1,rgb(167,167,167)),
        }
    })
    applyTheme(dropBg:FindFirstChildOfClass("UIGradient"),"contrast","Color")

    local dropContrast = create("Frame",{
        Parent=dropBg, Name="contrast",
        ZIndex=2, Size=dim2(1,0,1,0), BorderSizePixel=0,
        BackgroundColor3=rgb(255,255,255),
        -- Skibid: non-scrolling dropdown contrast has no AutomaticSize
    })
    create("UIGradient",{
        Parent=dropContrast, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1,themes.preset.high_contrast),
        }
    })
    applyTheme(dropContrast:FindFirstChildOfClass("UIGradient"),"contrast","Color")

    -- "+" / "-" indicator (right-aligned)
    local plusLbl = create("TextLabel",{
        Parent=dropContrast,
        TextWrapped=true,
        TextColor3=themes.preset.text,
        ZIndex=2,
        Text="+",
        Name="plus",
        Size=dim2(1,-4,1,0),
        Position=dim2(0,0,0,-1),
        BackgroundTransparency=1,
        TextXAlignment=Enum.TextXAlignment.Right,
        FontFace=customFont,
        TextTruncate=Enum.TextTruncate.AtEnd,
        BorderSizePixel=0,
        BackgroundColor3=rgb(255,255,255),
    })
    applyTheme(plusLbl,"text","TextColor3")

    -- selected value text (left-aligned)
    local valLbl = create("TextLabel",{
        Parent=dropContrast,
        FontFace=customFont,
        TextColor3=themes.preset.text,
        ZIndex=2,
        Text=tostring(default),
        Name="text",
        Size=dim2(1,-4,1,0),
        Position=dim2(0,4,0,-1),
        BackgroundTransparency=1,
        TextXAlignment=Enum.TextXAlignment.Left,
        TextTruncate=Enum.TextTruncate.AtEnd,
        TextSize=12, BorderSizePixel=0,
        BackgroundColor3=rgb(255,255,255),
    })
    applyTheme(valLbl,"text","TextColor3")

    -- Skibid: UIListLayout placed AFTER dropdown children
    create("UIListLayout",{
        Parent=bottomComp, Padding=dim(0,10),
        SortOrder=Enum.SortOrder.LayoutOrder,
    })

    -- ── floating dropdown holder (parented to ScreenGui) ──────────────────────
    local holderParent = _activeSG or CoreGui
    local floatHolder = create("Frame",{
        Parent=holderParent,
        Name="dropdown_holder",
        BackgroundTransparency=1,
        Position=dim2(0,0,0,0),
        Size=dim2(0,0,0,0),
        BorderSizePixel=0,
        AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundColor3=themes.preset.outline,
        Visible=false,
        ZIndex=100,
    })

    local floatIn = create("Frame",{
        Parent=floatHolder,
        Size=dim2(1,-2,1,2), Name="inline",
        Position=dim2(0,1,0,1),
        ZIndex=2, BorderSizePixel=0,
        BackgroundColor3=themes.preset.inline,
    })
    applyTheme(floatIn,"inline","BackgroundColor3")

    local floatBg = create("Frame",{
        Parent=floatIn,
        BackgroundTransparency=1,
        Name="background",
        Position=dim2(0,1,0,1), Size=dim2(1,-2,1,1),
        ZIndex=2, BorderSizePixel=0,
        BackgroundColor3=themes.preset.accent,
    })
    applyTheme(floatBg,"accent","BackgroundColor3")

    local floatContrast = create("Frame",{
        Parent=floatBg,
        Name="contrast",
        ZIndex=2, BorderSizePixel=0,
        Size=dim2(1,0,1,-3),
        BackgroundColor3=rgb(255,255,255),
        AutomaticSize=Enum.AutomaticSize.Y,
    })
    create("UIPadding",{
        Parent=floatContrast,
        PaddingTop=dim(0,2), PaddingBottom=dim(0,2),
        PaddingLeft=dim(0,4),
    })
    create("UIGradient",{
        Parent=floatContrast, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1,themes.preset.high_contrast),
        }
    })
    applyTheme(floatContrast:FindFirstChildOfClass("UIGradient"),"contrast","Color")
    create("UIListLayout",{
        Parent=floatContrast, Padding=dim(0,5),
        SortOrder=Enum.SortOrder.LayoutOrder,
    })

    local stroke = Instance.new("UIStroke")
    stroke.Color        = themes.preset.outline
    stroke.LineJoinMode = Enum.LineJoinMode.Miter
    stroke.Parent       = floatIn
    applyTheme(stroke,"outline","Color")

    -- ── helper: update position of floating holder ─────────────────────────────
    local function updateHolderPos()
        floatHolder.Size     = dim2(0, dropBtn.AbsoluteSize.X, 0, floatHolder.Size.Y.Offset)
        floatHolder.Position = dim2(0, dropBtn.AbsolutePosition.X + 1, 0, dropBtn.AbsolutePosition.Y + 22)
    end

    -- ── build option buttons ───────────────────────────────────────────────────
    local function buildOptions(list)
        -- clear old
        for _, v in pairs(optionInstances) do v:Destroy() end
        optionInstances = {}

        for _, v in ipairs(list) do
            local optBtn = create("TextButton",{
                Parent=floatContrast,
                FontFace=customFont,
                TextColor3=themes.preset.accent,  -- Skibid: apply_theme "accent" on TextColor3
                Size=dim2(1,0,0,0),
                BackgroundTransparency=1,
                BorderSizePixel=0,
                TextWrapped=true,
                AutomaticSize=Enum.AutomaticSize.Y,
                TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Left,
                ZIndex=2,
                Text=v,
                BackgroundColor3=rgb(255,255,255),
                AutoButtonColor=false,
            })
            applyTheme(optBtn,"accent","TextColor3")
            table.insert(optionInstances, optBtn)

            optBtn.MouseButton1Down:Connect(function()
                selectedValue = v
                valLbl.Text   = tostring(v)
                -- close
                openState             = false
                floatHolder.Visible   = false
                plusLbl.Text          = "+"
                safeCall(callback, v)
            end)
            optBtn.MouseEnter:Connect(function()
                tween(optBtn,{TextColor3=themes.preset.text})
            end)
            optBtn.MouseLeave:Connect(function()
                tween(optBtn,{TextColor3=themes.preset.accent})
            end)
        end
    end

    buildOptions(items)

    -- toggle open/close
    dropBtn.MouseButton1Click:Connect(function()
        openState = not openState
        if openState then
            updateHolderPos()
        end
        floatHolder.Visible = openState
        plusLbl.Text  = openState and "-" or "+"
        plusLbl.TextSize = openState and 12 or 8
    end)

    -- hover effect (Skibid: hoverify tweens overlay transparency)
    root.MouseEnter:Connect(function()
        tween(dropHover,{BackgroundTransparency=0})
    end)
    root.MouseLeave:Connect(function()
        tween(dropHover,{BackgroundTransparency=1})
    end)

    return root, function() return selectedValue end
end

