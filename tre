-- ── Save config ───────────────────────────────────────────────────────────────
function WindowAPI:saveConfig(name)
    local data = {}
    for key, entry in pairs(self._cfg._entries) do
        local val = entry.get()
        local serialised = _cfgSerialise(entry.type, val)
        if serialised ~= nil then
            data[key] = serialised
        end
    end
    local json = HttpService:JSONEncode(data)
    -- ensure configs/ folder exists
    if not isfolder("configs") then makefolder("configs") end
    writefile("configs/"..name..".json", json)
end

-- ── Load config ───────────────────────────────────────────────────────────────
-- Returns true on success, false if file not found, errors on parse failure.
function WindowAPI:loadConfig(name)
    local path = "configs/"..name..".json"
    if not isfile(path) then return false end
    local json = readfile(path)
    local data = HttpService:JSONDecode(json)
    for key, raw in pairs(data) do
        local entry = self._cfg._entries[key]
        if entry then
            local val = _cfgDeserialise(entry.type, raw)
            if val ~= nil then
                safeCall(entry.set, val)
            end
        end
    end
    return true
end

function WindowAPI:destroy()
    self._gui:Destroy()
    for _,c in pairs(connections) do c:Disconnect() end
    connections = {}
end

