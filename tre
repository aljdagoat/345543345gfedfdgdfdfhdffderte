    applyTheme(tabBarOutline, "inline", "BackgroundColor3")
    local tabBarInline = create("Frame", {
        Parent = tabBarOutline, Position = dim2(0, 1, 0, 1),
        Size = dim2(1, -2, 1, -2), BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.outline
    })
    applyTheme(tabBarInline, "outline", "BackgroundColor3")
    local tabBarHolder = create("Frame", {
        Parent = tabBarInline, Position = dim2(0, 1, 0, 1),
        Size = dim2(1, -2, 1, -2), BorderSizePixel = 0,
        BackgroundColor3 = rgb(255, 255, 255)
    })
    local tabBarGradient = create("UIGradient", {
        Parent = tabBarHolder, Rotation = 90,
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1, themes.preset.high_contrast)
        }
    })
    applyTheme(tabBarGradient, "contrast", "Color")
    create("UIListLayout", {
        Parent = tabBarHolder, FillDirection = Enum.FillDirection.Horizontal,
        Padding = dim(0, 2), SortOrder = Enum.SortOrder.LayoutOrder
    })
    create("UIPadding", {
        Parent = tabBarHolder, PaddingLeft = dim(0, 2),
        PaddingTop = dim(0, 1), PaddingBottom = dim(0, 1)
    })

    -- Main content area
    local mainOutline = create("Frame", {
        Parent = windowHolder, Name = "outline",
        Position = dim2(0, 0, 0, 40), Size = dim2(1, 0, 1, -40),
        BorderSizePixel = 0, BackgroundColor3 = themes.preset.inline
    })
    applyTheme(mainOutline, "inline", "BackgroundColor3")
    local mainInline = create("Frame", {
        Parent = mainOutline, Name = "inline",
        Position = dim2(0, 1, 0, 1), Size = dim2(1, -2, 1, -2),
        BorderSizePixel = 0, BackgroundColor3 = themes.preset.outline
    })
    applyTheme(mainInline, "outline", "BackgroundColor3")
    local mainContentHolder = create("Frame", {
        Parent = mainInline, Name = "holder",
        Position = dim2(0, 1, 0, 1), Size = dim2(1, -2, 1, -2),
        BorderSizePixel = 0, BackgroundColor3 = rgb(255, 255, 255)
    })
    local mainContentGradient = create("UIGradient", {
        Parent = mainContentHolder, Rotation = 90,
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1, themes.preset.high_contrast)
        }
    })
    applyTheme(mainContentGradient, "contrast", "Color")

    -- Glow effect
    local glow = create("ImageLabel", {
        Parent = mainFrame, Name = "glow",
        ImageColor3 = themes.preset.glow,
        ScaleType = Enum.ScaleType.Slice,
        BorderColor3 = rgb(0, 0, 0),
        BackgroundColor3 = rgb(255, 255, 255),
        Image = "http://www.roblox.com/asset/?id=18245826428",
        BackgroundTransparency = 1, ImageTransparency = 0.8,
        Position = dim2(0, -20, 0, -20), Size = dim2(1, 40, 1, 40),
        ZIndex = 2, BorderSizePixel = 0,
        SliceCenter = Rect.new(Vector2.new(21, 21), Vector2.new(79, 79))
    })
    applyTheme(glow, "glow", "ImageColor3")

    -- Tab button factory (closure over tabBarHolder)
    local function createTabBtn(name, order)
        local btn = create("TextButton", {
            Parent = tabBarHolder, Name = name, FontFace = customFont,
            Text = name, TextColor3 = themes.preset.text,
            BackgroundTransparency = 1, Size = dim2(0, 0, 1, 0),
            AutomaticSize = Enum.AutomaticSize.X,
            BorderSizePixel = 0, TextSize = 12, LayoutOrder = order,
            BackgroundColor3 = rgb(255, 255, 255)
        })
        create("UIPadding", {
            Parent = btn, PaddingLeft = dim(0, 6), PaddingRight = dim(0, 6)
        })
        local indicator = create("Frame", {
            Parent = btn, Name = "active_indicator",
            Position = dim2(0, 0, 1, -1), Size = dim2(1, 0, 0, 1),
            BackgroundColor3 = themes.preset.accent, BorderSizePixel = 0, Visible = false
        })
        applyTheme(indicator, "accent", "BackgroundColor3")
        return btn, indicator
    end

    local win = setmetatable({
        _screenGui    = screenGui,
        _contentHolder = mainContentHolder,
        _tabs          = {},
        _tabOrder      = 1,
        _createTabBtn  = createTabBtn,
    }, WindowAPI)

    -- Always include a built-in Theme tab at the end
    -- (call addTab("Theme") yourself if you want it in a custom position,
    --  or it's automatically added after all user tabs via addThemeTab)
    function win:addThemeTab()
        local content, container = _makeScrollContent(self._contentHolder)
        -- Override scroll to use standard padding
        local themeLabel = create("TextLabel", {
            Parent = container, FontFace = customFont,
            Text = "Theme Customization", TextColor3 = themes.preset.accent,
            BackgroundTransparency = 1, Size = dim2(1, 0, 0, 16),
            TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left,
            LayoutOrder = 1
        })
        applyTheme(themeLabel, "accent", "TextColor3")
        _makeThemeColorPicker(container, "Outline",       "outline",       10)
        _makeThemeColorPicker(container, "Inline",        "inline",        11)
        _makeThemeColorPicker(container, "Accent",        "accent",        12)
        _makeThemeColorPicker(container, "High Contrast", "high_contrast", 13)
        _makeThemeColorPicker(container, "Low Contrast",  "low_contrast",  14)
        _makeThemeColorPicker(container, "Text",          "text",          15)
        _makeThemeColorPicker(container, "Glow",          "glow",          16)

        local btn, indicator = self._createTabBtn("Theme", self._tabOrder)
        self._tabOrder = self._tabOrder + 1
        self._tabs["Theme"] = { button = btn, indicator = indicator, content = content }
        btn.MouseButton1Click:Connect(function() self:_switchTab("Theme") end)
    end

    screenGui.AncestryChanged:Connect(function()
        if not screenGui.Parent then
            for _, c in pairs(connections) do c:Disconnect() end
            connections = {}
        end
    end)

    screenGui.Enabled = true
    return win
end

return UILib
