    local hG = create("UIGradient",{ Parent=hH, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1,themes.preset.high_contrast),
        }})
    applyTheme(hG,"contrast","Color")
    local hexBox = create("TextBox",{ Parent=hH, FontFace=customFont,
        TextColor3=themes.preset.text,
        Text="#"..themes.preset[themeKey]:ToHex():upper(),
        PlaceholderText="#RRGGBB", BackgroundTransparency=1,
        Size=dim2(1,-4,1,0), Position=dim2(0,2,0,0),
        TextSize=12, TextXAlignment=Enum.TextXAlignment.Left,
        ClearTextOnFocus=false, BorderSizePixel=0 })
    hexBox.FocusLost:Connect(function()
        local raw = hexBox.Text:gsub("#","")
        if #raw==6 and raw:match("^%x+$") then
            local c = hex("#"..raw)
            themes.preset[themeKey] = c
            preview.BackgroundColor3 = c
            hexBox.Text = "#"..raw:upper()
            updateTheme()
        else
            hexBox.Text = "#"..themes.preset[themeKey]:ToHex():upper()
        end
    end)
    return pOut
end

