-- ── Toggle – fix #2 (debounce, single setState, pcall) ───────────────────────
local function _makeToggle(parent, label, default, callback, order)
    assert(type(default)=="boolean", "[UILib] toggle default must be boolean: "..label)

    local card, holder = makeCard(parent, 28, order)
    card.Name = label:gsub(" ","_")
    create("UIPadding",{ Parent=holder, PaddingLeft=dim(0,7), PaddingRight=dim(0,7) })
    local bar = makeAccentBar(holder, default)

    create("TextLabel",{
        Parent=holder, FontFace=customFont, Text=label,
        TextColor3=themes.preset.text, BackgroundTransparency=1,
        Position=dim2(0,0,0,0), Size=dim2(1,-38,1,0),
        TextSize=12, TextXAlignment=Enum.TextXAlignment.Left,
    })

    local PILL_W, PILL_H = 28, 14
    local trkOut = create("Frame",{
        Parent=holder, AnchorPoint=vec2(1,0.5),
        Position=dim2(1,0,0.5,0), Size=dim2(0,PILL_W+2,0,PILL_H+2),
        BackgroundColor3=themes.preset.outline, BorderSizePixel=0,
    })
    applyTheme(trkOut,"outline","BackgroundColor3")
    local trkIn = create("Frame",{
        Parent=trkOut, Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
        BorderSizePixel=0, BackgroundColor3=themes.preset.inline,
    })
    applyTheme(trkIn,"inline","BackgroundColor3")
    local track = create("Frame",{
        Parent=trkIn, Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
        BorderSizePixel=0,
        BackgroundColor3=default and themes.preset.accent or themes.preset.high_contrast,
    })
    if default then applyTheme(track,"accent","BackgroundColor3") end

    local TS = PILL_H - 4
    local ON_X, OFF_X = PILL_W-TS-3, 2
    local thumb = create("Frame",{
        Parent=track, Size=dim2(0,TS,0,TS),
        Position=dim2(0, default and ON_X or OFF_X, 0.5, -TS/2),
        BackgroundColor3=default and rgb(255,255,255) or themes.preset.inline,
        BorderSizePixel=0,
    })

    local clickBtn = create("TextButton",{
        Parent=holder, Size=dim2(1,0,1,0), BackgroundTransparency=1,
        Text="", BorderSizePixel=0, AutoButtonColor=false, ZIndex=10,
    })

    local state = default
    local busy  = false

    local function setState(val)
        state = val
        tween(track, { BackgroundColor3=val and themes.preset.accent or themes.preset.high_contrast })
        tween(thumb, {
            Position         = dim2(0, val and ON_X or OFF_X, 0.5, -TS/2),
            BackgroundColor3 = val and rgb(255,255,255) or themes.preset.inline,
        })
        tween(bar, { BackgroundTransparency=val and 0 or 1 })
        safeCall(callback, val)
    end

    clickBtn.MouseButton1Click:Connect(function()
        if busy then return end
        busy = true
        setState(not state)
        task.delay(0.15, function() busy=false end)
    end)
    clickBtn.MouseEnter:Connect(function() tween(holder,{BackgroundColor3=themes.preset.low_contrast}) end)
    clickBtn.MouseLeave:Connect(function() tween(holder,{BackgroundColor3=rgb(255,255,255)}) end)

    return card, function() return state end
end

-- ── Slider – fix #3 (single bool, AbsolutePosition math, clamped, 2dp) ───────
local function _makeSlider(parent, label, min, max, default, callback, order)
    assert(min < max, "[UILib] slider min must be < max: "..label)
    default = math.clamp(default, min, max)

    local card, holder = makeCard(parent, 40, order)
    card.Name = label:gsub(" ","_")
    create("UIPadding",{ Parent=holder,
        PaddingLeft=dim(0,7), PaddingRight=dim(0,7),
        PaddingTop=dim(0,5),  PaddingBottom=dim(0,5),
    })
    makeAccentBar(holder, true)

    -- top row
    local topRow = create("Frame",{ Parent=holder, Size=dim2(1,0,0,12),
        BackgroundTransparency=1, BorderSizePixel=0 })
    create("TextLabel",{
        Parent=topRow, FontFace=customFont, Text=label,
        TextColor3=themes.preset.text, BackgroundTransparency=1,
        Size=dim2(1,-40,1,0), TextSize=12, TextXAlignment=Enum.TextXAlignment.Left,
    })

    -- value pill
    local vOut = create("Frame",{ Parent=topRow, AnchorPoint=vec2(1,0),
        Position=dim2(1,0,0,0), Size=dim2(0,38,0,12),
        BackgroundColor3=themes.preset.outline, BorderSizePixel=0 })
    applyTheme(vOut,"outline","BackgroundColor3")
    local vIn = create("Frame",{ Parent=vOut, Position=dim2(0,1,0,1),
        Size=dim2(1,-2,1,-2), BorderSizePixel=0, BackgroundColor3=themes.preset.inline })
    applyTheme(vIn,"inline","BackgroundColor3")
    local vH = create("Frame",{ Parent=vIn, Position=dim2(0,1,0,1),
        Size=dim2(1,-2,1,-2), BorderSizePixel=0, BackgroundColor3=rgb(255,255,255) })
    local vG = create("UIGradient",{ Parent=vH, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1,themes.preset.high_contrast),
        }})
    applyTheme(vG,"contrast","Color")
    local valLbl = create("TextLabel",{
        Parent=vH, FontFace=customFont, Text=string.format("%.2f",default),
        TextColor3=themes.preset.accent, BackgroundTransparency=1,
        Size=dim2(1,0,1,0), TextSize=10, TextXAlignment=Enum.TextXAlignment.Center,
    })
    applyTheme(valLbl,"accent","TextColor3")

    -- track
    local trkRow = create("Frame",{ Parent=holder, Position=dim2(0,0,0,16),
        Size=dim2(1,0,0,8), BackgroundTransparency=1, BorderSizePixel=0 })
    local trkOut = create("Frame",{ Parent=trkRow, Size=dim2(1,0,0,8),
        BackgroundColor3=themes.preset.outline, BorderSizePixel=0 })
    applyTheme(trkOut,"outline","BackgroundColor3")
    local trkIn = create("Frame",{ Parent=trkOut, Position=dim2(0,1,0,1),
        Size=dim2(1,-2,1,-2), BorderSizePixel=0,
        BackgroundColor3=themes.preset.high_contrast })
    applyTheme(trkIn,"high_contrast","BackgroundColor3")

    local initR = (default-min)/(max-min)
    local fill  = create("Frame",{ Parent=trkIn, Size=dim2(initR,0,1,0),
        BackgroundColor3=themes.preset.accent, BorderSizePixel=0 })
    applyTheme(fill,"accent","BackgroundColor3")

    local THUMB = 10
    local thumb = create("Frame",{
        Parent=trkOut, AnchorPoint=vec2(0.5,0.5),
        Position=dim2(initR,0,0.5,0), Size=dim2(0,THUMB,0,THUMB),
        BackgroundColor3=rgb(255,255,255), BorderSizePixel=0, ZIndex=3,
    })
    local dot = create("Frame",{ Parent=thumb, AnchorPoint=vec2(0.5,0.5),
        Position=dim2(0.5,0,0.5,0), Size=dim2(0,4,0,4),
        BackgroundColor3=themes.preset.accent, BorderSizePixel=0, ZIndex=4 })
    applyTheme(dot,"accent","BackgroundColor3")

    local cur      = default
    local dragging = false

    local function applyRatio(ratio)
        ratio = math.clamp(ratio, 0, 1)
        cur   = math.floor((min + (max-min)*ratio)*100)/100
        fill.Size       = dim2(ratio,0,1,0)
        thumb.Position  = dim2(ratio,0,0.5,0)
        valLbl.Text     = string.format("%.2f", cur)
        safeCall(callback, cur)
    end

    local function onInput(inp)
        applyRatio((inp.Position.X - trkIn.AbsolutePosition.X) / trkIn.AbsoluteSize.X)
    end

    trkOut.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging=true; onInput(inp)
        end
    end)
    trkOut.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging=false end
    end)
    conn(UserInputService.InputChanged, function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then onInput(inp) end
    end)

    return card, function() return cur end
end

-- ── Keybind – fix #4 (unknown filter, outside-click cancel) ──────────────────
local function _makeKeybind(parent, label, defaultKey, callback, order)
    local card, holder = makeCard(parent, 28, order)
    card.Name = label:gsub(" ","_")
    create("UIPadding",{ Parent=holder, PaddingLeft=dim(0,7), PaddingRight=dim(0,7) })
    makeAccentBar(holder, true)

    create("TextLabel",{
        Parent=holder, FontFace=customFont, Text=label,
        TextColor3=themes.preset.text, BackgroundTransparency=1,
        Position=dim2(0,0,0,0), Size=dim2(1,-70,1,0),
        TextSize=12, TextXAlignment=Enum.TextXAlignment.Left,
    })

    local bOut = create("Frame",{ Parent=holder, AnchorPoint=vec2(1,0.5),
        Position=dim2(1,0,0.5,0), Size=dim2(0,66,0,16),
        BackgroundColor3=themes.preset.outline, BorderSizePixel=0 })
    applyTheme(bOut,"outline","BackgroundColor3")
    local bIn = create("Frame",{ Parent=bOut, Position=dim2(0,1,0,1),
        Size=dim2(1,-2,1,-2), BorderSizePixel=0, BackgroundColor3=themes.preset.inline })
    applyTheme(bIn,"inline","BackgroundColor3")
    local bH = create("Frame",{ Parent=bIn, Position=dim2(0,1,0,1),
        Size=dim2(1,-2,1,-2), BorderSizePixel=0, BackgroundColor3=rgb(255,255,255) })
    local bG = create("UIGradient",{ Parent=bH, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1,themes.preset.high_contrast),
        }})
    applyTheme(bG,"contrast","Color")
    local badgeBtn = create("TextButton",{
        Parent=bH, FontFace=customFont,
        Text=defaultKey.Name, TextColor3=themes.preset.accent,
        BackgroundTransparency=1, Size=dim2(1,0,1,0),
        TextSize=10, AutoButtonColor=false, TextXAlignment=Enum.TextXAlignment.Center,
    })
    applyTheme(badgeBtn,"accent","TextColor3")
    local overlay = create("Frame",{ Parent=bH, Size=dim2(1,0,1,0),
        BackgroundColor3=themes.preset.accent,
        BackgroundTransparency=1, BorderSizePixel=0, ZIndex=5 })
    applyTheme(overlay,"accent","BackgroundColor3")

    local curKey     = defaultKey
    local listening  = false
    local listenConn = nil

    local function stopListening(cancelled)
        if not listening then return end
        listening = false
        if listenConn then listenConn:Disconnect(); listenConn=nil end
        tween(badgeBtn,{ TextColor3=themes.preset.accent })
        tween(overlay,{ BackgroundTransparency=1 })
        if cancelled then badgeBtn.Text=curKey.Name end
    end

    local function startListening()
        if listening then return end
        listening     = true
        badgeBtn.Text = "..."
        tween(badgeBtn,{ TextColor3=themes.preset.text })
        tween(overlay,{ BackgroundTransparency=0.82 })

        listenConn = UserInputService.InputBegan:Connect(function(inp, processed)
            if processed then return end
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                stopListening(true); return
            end
            if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
            if inp.KeyCode == Enum.KeyCode.Unknown then return end
            curKey        = inp.KeyCode
            badgeBtn.Text = inp.KeyCode.Name
            stopListening(false)
            safeCall(callback, curKey)
        end)
    end

    badgeBtn.MouseButton1Click:Connect(startListening)
    badgeBtn.MouseEnter:Connect(function() tween(bH,{BackgroundColor3=themes.preset.low_contrast}) end)
    badgeBtn.MouseLeave:Connect(function()
        if not listening then tween(bH,{BackgroundColor3=rgb(255,255,255)}) end
    end)

    return card, function() return curKey end
end

