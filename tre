-- ─────────────────────────────────────────────────────────────────────────────
-- CONFIG REGISTRY
-- A window-local table that tracks every registered control so configs
-- can be serialised / deserialised without the caller doing any extra work.
-- ─────────────────────────────────────────────────────────────────────────────
local function _newCfgRegistry()
    local reg = { _entries = {} }
    -- type = "bool" | "number" | "string" | "color" | "key"
    function reg:register(key, getter, setter, ctype)
        self._entries[key] = { get=getter, set=setter, type=ctype }
    end
    return reg
end

-- Serialise a single value to a JSON-safe type
local function _cfgSerialise(ctype, val)
    if ctype == "bool"   then return val
    elseif ctype == "number" then return val
    elseif ctype == "string" then return tostring(val)
    elseif ctype == "color" then
        -- val is Color3
        return "#"..val:ToHex():upper()
    elseif ctype == "key" then
        return val and val.Name or "None"
    end
    return nil
end

-- Deserialise back from JSON value
local function _cfgDeserialise(ctype, val)
    if ctype == "bool"   then return (val == true)
    elseif ctype == "number" then return tonumber(val) or 0
    elseif ctype == "string" then return tostring(val)
    elseif ctype == "color" then
        local raw = tostring(val):gsub("#","")
        if #raw==6 and raw:match("^%x+$") then return hex("#"..raw) end
        return nil
    elseif ctype == "key" then
        if val == "None" or not val then return nil end
        local ok,kc = pcall(function() return Enum.KeyCode[val] end)
        return ok and kc or nil
    end
    return nil
end

