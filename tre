-- ── Draggable ─────────────────────────────────────────────────────────────────
local function makeDraggable(frame, handle)
    handle = handle or frame
    local dragging, startMouse, startFrame = false, nil, nil
    handle.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging   = true
            startMouse = inp.Position
            startFrame = frame.Position
        end
    end)
    handle.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging=false end
    end)
    conn(UserInputService.InputChanged, function(inp)
        if not dragging or inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local vp = Camera.ViewportSize
        frame.Position = dim2(0,
            math.clamp(startFrame.X.Offset + (inp.Position.X - startMouse.X), 0, vp.X - frame.AbsoluteSize.X),
            0,
            math.clamp(startFrame.Y.Offset + (inp.Position.Y - startMouse.Y), 0, vp.Y - frame.AbsoluteSize.Y)
        )
    end)
end

-- ── Resizable ─────────────────────────────────────────────────────────────────
local MIN_W, MIN_H = 280, 200
local function makeResizable(frame)
    local grip      = Instance.new("TextButton")
    grip.Size       = dim2(0,10,0,10)
    grip.Position   = dim2(1,-10,1,-10)
    grip.BackgroundTransparency = 1
    grip.Text       = ""
    grip.ZIndex     = 200
    grip.Parent     = frame

    local resizing, startMouse, startSize = false, nil, nil
    grip.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing   = true
            startMouse = inp.Position
            startSize  = frame.Size
        end
    end)
    grip.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then resizing=false end
    end)
    conn(UserInputService.InputChanged, function(inp)
        if not resizing or inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local vp = Camera.ViewportSize
        frame.Size = dim2(0,
            math.clamp(startSize.X.Offset + (inp.Position.X - startMouse.X), MIN_W, vp.X),
            0,
            math.clamp(startSize.Y.Offset + (inp.Position.Y - startMouse.Y), MIN_H, vp.Y)
        )
    end)
end

