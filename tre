-- ── Global connection table ───────────────────────────────────────────────────
local connections = {}
local function conn(signal, fn)
    local c = signal:Connect(fn)
    table.insert(connections, c)
    return c
end

-- ── Popup manager ─────────────────────────────────────────────────────────────
local _activePopups = {}

local function tween(obj, props, t)
    local tw = TweenService:Create(obj,
        TweenInfo.new(t or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props)
    tw:Play()
    return tw
end

local function _closePopupAnimated(frame, onDone)
    if not frame or not frame.Parent then return end
    local origSize = frame.Size
    tween(frame, { Size = UDim2.new(0, origSize.X.Offset, 0, 0) }, 0.12)
    task.delay(0.12, function()
        if frame and frame.Parent then
            frame.Visible = false
            frame.Size = origSize
        end
        if onDone then onDone() end
    end)
end

local function _closeAllPopups()
    for frame, meta in pairs(_activePopups) do
        if frame and frame.Parent then
            if meta.animator then meta.animator(frame, meta.onClose)
            else _closePopupAnimated(frame, meta.onClose) end
        end
    end
    table.clear(_activePopups)
end

local function _registerPopup(frame, onClose, animator)
    _closeAllPopups()
    _activePopups[frame] = { onClose=onClose, animator=animator }
end

local function _unregisterPopup(frame)
    _activePopups[frame] = nil
end

local _popupListenersReady = false
local function _ensurePopupListeners()
    if _popupListenersReady then return end
    _popupListenersReady = true
    conn(UserInputService.InputBegan, function(inp, gpe)
        if gpe then return end
        if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        local mouse = UserInputService:GetMouseLocation()
        for frame in pairs(_activePopups) do
            if frame and frame.Parent and frame.Visible then
                local pos  = frame.AbsolutePosition
                local size = frame.AbsoluteSize
                local inside =
                    mouse.X >= pos.X and mouse.X <= pos.X+size.X and
                    mouse.Y >= pos.Y and mouse.Y <= pos.Y+size.Y
                if not inside then
                    local meta = _activePopups[frame]
                    _activePopups[frame] = nil
                    if meta and meta.animator then meta.animator(frame, meta.onClose)
                    else _closePopupAnimated(frame, meta and meta.onClose) end
                end
            end
        end
    end)
    conn(UserInputService.InputBegan, function(inp)
        if inp.KeyCode == Enum.KeyCode.Escape then _closeAllPopups() end
    end)
end

-- ── Safe callback ─────────────────────────────────────────────────────────────
local function safeCall(fn, ...)
    if type(fn) ~= "function" then return end
    local ok, err = pcall(fn, ...)
    if not ok then warn("[UILib] callback error:", err) end
end

-- ── Theme helpers ─────────────────────────────────────────────────────────────
local function applyTheme(inst, theme, prop)
    if themes.utility[theme] and themes.utility[theme][prop] then
        table.insert(themes.utility[theme][prop], inst)
    end
end

local function updateTheme()
    for tname, props in pairs(themes.utility) do
        for pname, list in pairs(props) do
            for _, inst in pairs(list) do
                if inst and inst.Parent then
                    if tname == "contrast" then
                        inst[pname] = ColorSequence.new{
                            ColorSequenceKeypoint.new(0, themes.preset.low_contrast),
                            ColorSequenceKeypoint.new(1, themes.preset.high_contrast),
                        }
                    elseif themes.preset[tname] then
                        inst[pname] = themes.preset[tname]
                    end
                end
            end
        end
    end
end

-- ── Instance factory ──────────────────────────────────────────────────────────
local function create(itype, props)
    local inst = Instance.new(itype)
    for k, v in pairs(props) do inst[k] = v end
    if itype=="TextLabel" or itype=="TextButton" or itype=="TextBox" then
        applyTheme(inst, "text", "TextColor3")
        local s = Instance.new("UIStroke")
        s.Color        = themes.preset.text_outline
        s.LineJoinMode = Enum.LineJoinMode.Miter
        s.Parent       = inst
        applyTheme(s, "text_outline", "Color")
    end
    return inst
end

-- ── Draggable / Resizable ─────────────────────────────────────────────────────
local function makeDraggable(frame, handle)
    handle = handle or frame
    local dragging, startMouse, startFrame = false, nil, nil
    handle.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging=true; startMouse=inp.Position; startFrame=frame.Position
        end
    end)
    handle.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging=false end
    end)
    conn(UserInputService.InputChanged, function(inp)
        if not dragging or inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local vp = Camera.ViewportSize
        frame.Position = dim2(0,
            math.clamp(startFrame.X.Offset+(inp.Position.X-startMouse.X), 0, vp.X-frame.AbsoluteSize.X),
            0,
            math.clamp(startFrame.Y.Offset+(inp.Position.Y-startMouse.Y), 0, vp.Y-frame.AbsoluteSize.Y))
    end)
end

local MIN_W, MIN_H = 280, 200
local function makeResizable(frame)
    local grip = Instance.new("TextButton")
    grip.Size=dim2(0,10,0,10); grip.Position=dim2(1,-10,1,-10)
    grip.BackgroundTransparency=1; grip.Text=""; grip.ZIndex=200; grip.Parent=frame
    local resizing, startMouse, startSize = false,nil,nil
    grip.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then
            resizing=true; startMouse=inp.Position; startSize=frame.Size
        end
    end)
    grip.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then resizing=false end
    end)
    conn(UserInputService.InputChanged, function(inp)
        if not resizing or inp.UserInputType~=Enum.UserInputType.MouseMovement then return end
        local vp = Camera.ViewportSize
        frame.Size = dim2(0,
            math.clamp(startSize.X.Offset+(inp.Position.X-startMouse.X), MIN_W, vp.X),
            0,
            math.clamp(startSize.Y.Offset+(inp.Position.Y-startMouse.Y), MIN_H, vp.Y))
    end)
end

