    -- ── Styled text-input row ─────────────────────────────────────────────────
    local function makeInputRow(parent2, placeholder, order)
        local cardOut = create("Frame",{
            Parent=parent2, Size=dim2(1,0,0,22),
            BorderSizePixel=0, BackgroundColor3=themes.preset.outline, LayoutOrder=order,
        })
