-- ── Section ───────────────────────────────────────────────────────────────────
local function _makeSection(parent, title, order)
    -- Outer: inline bg color, 1px border via UIPadding
    local sec = create("Frame",{
        Parent=parent, Name=title:gsub(" ","_"),
        Size=dim2(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundColor3=themes.preset.inline,
        BorderSizePixel=0, LayoutOrder=order,
    })
    applyTheme(sec,"inline","BackgroundColor3")
    create("UIPadding",{ Parent=sec,
        PaddingLeft=dim(0,1), PaddingRight=dim(0,1),
        PaddingTop=dim(0,1), PaddingBottom=dim(0,1),
    })

    -- Middle: outline bg color, 1px border via UIPadding
    local secInline = create("Frame",{
        Parent=sec,
        Size=dim2(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundColor3=themes.preset.outline, BorderSizePixel=0,
    })
    applyTheme(secInline,"outline","BackgroundColor3")
    create("UIPadding",{ Parent=secInline,
        PaddingLeft=dim(0,1), PaddingRight=dim(0,1),
        PaddingTop=dim(0,1), PaddingBottom=dim(0,1),
    })

    -- Inner background: white tinted by dark contrast gradient
    local secBg = create("Frame",{
        Parent=secInline,
        Size=dim2(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundColor3=rgb(255,255,255), BorderSizePixel=0,
    })

    -- Skibid: title at Position=dim2(0,6,0,4), AutomaticSize=XY
    create("TextLabel",{
        Parent=secBg, FontFace=customFont, Text=title,
        TextColor3=themes.preset.text, BackgroundTransparency=1,
        Position=dim2(0,6,0,4), BorderSizePixel=0,
        AutomaticSize=Enum.AutomaticSize.XY, TextSize=12,
        BackgroundColor3=rgb(255,255,255),
    })

    -- Skibid: accent top bar Size=dim2(1,0,0,2)
    local accentBar = create("Frame",{
        Parent=secBg, Size=dim2(1,0,0,2), BorderSizePixel=0,
        BackgroundColor3=themes.preset.accent,
    })
    applyTheme(accentBar,"accent","BackgroundColor3")
    create("UIGradient",{
        Parent=accentBar, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,rgb(255,255,255)),
            ColorSequenceKeypoint.new(1,rgb(167,167,167)),
        }
    })

    -- Skibid: dark contrast gradient on background frame
    local bgGrad = create("UIGradient",{
        Parent=secBg, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1,themes.preset.high_contrast),
        }
    })
    applyTheme(bgGrad,"contrast","Color")

    -- Elements container starts 20px down (below title)
    local elements = create("Frame",{
        Parent=secBg, Name="elements",
        Position=dim2(0,0,0,20), Size=dim2(1,0,0,0),
        AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundTransparency=1, BorderSizePixel=0,
    })
    create("UIListLayout",{
        Parent=elements, Padding=dim(0,4),
        HorizontalAlignment=Enum.HorizontalAlignment.Center,
        SortOrder=Enum.SortOrder.LayoutOrder,
    })
    create("UIPadding",{
        Parent=elements, PaddingBottom=dim(0,10),
    })

    return elements
end

-- ── Toggle  (Skibid: 14×14 square checkbox, accent fill fades in/out) ─────────
-- Optional keybind: pass a KeyCode as last arg to get a small badge on the right.
local function _makeToggle(parent, label, default, callback, order, defaultKey)
    assert(type(default)=="boolean", "[UILib] toggle default must be boolean: "..label)

    -- outer row: transparent, full-width, 12px tall (Skibid: dim2(1,-8,0,12) + AutomaticSize.Y)
    local row = create("TextButton",{
        Parent=parent, Name=label:gsub(" ","_"),
        Size=dim2(1,-8,0,12), BorderSizePixel=0,
        BackgroundTransparency=1,
        Text="", AutoButtonColor=false,
        TextXAlignment=Enum.TextXAlignment.Left,
        AutomaticSize=Enum.AutomaticSize.Y,
        TextYAlignment=Enum.TextYAlignment.Top,
        FontFace=customFont, TextSize=12,
        TextColor3=themes.preset.text,
        LayoutOrder=order or 0,
        ZIndex=1,
    })

    -- right_components: AnchorPoint=vec2(1,0.5) so it hugs the right edge inward
    local right_components = create("Frame",{
        Parent=row, Name="right_components",
        AnchorPoint=vec2(1,0.5),
        Position=dim2(1,-1,0.5,0),
        Size=dim2(0,0,0,12), BorderSizePixel=0,
        AutomaticSize=Enum.AutomaticSize.X,
        BackgroundTransparency=1,
        BackgroundColor3=rgb(255,255,255),
    })
    create("UIListLayout",{
        Parent=right_components,
        VerticalAlignment=Enum.VerticalAlignment.Center,
        FillDirection=Enum.FillDirection.Horizontal,
        HorizontalAlignment=Enum.HorizontalAlignment.Right,
        Padding=dim(0,4),
        SortOrder=Enum.SortOrder.LayoutOrder,
    })

    -- UIPadding on toggle_holder (Skibid: empty UIPadding)
    create("UIPadding",{ Parent=row })

    -- label text (left side)
    local labelFrame = create("Frame",{
        Parent=row, Name="left_components",
        BackgroundTransparency=1,
        Position=dim2(0,0,0,0),
        Size=dim2(0,0,0,14), BorderSizePixel=0,
        BackgroundColor3=rgb(255,255,255),
    })
    create("UIListLayout",{
        Parent=labelFrame, Padding=dim(0,5),
        FillDirection=Enum.FillDirection.Horizontal,
    })
    local textLbl = create("TextLabel",{
        Parent=labelFrame, FontFace=customFont,
        Text=label, TextColor3=themes.preset.text,
        BackgroundTransparency=1, Size=dim2(0,0,1,-1),
        AutomaticSize=Enum.AutomaticSize.X,
        BorderSizePixel=0, TextSize=12,
        BackgroundColor3=rgb(255,255,255),
    })
    applyTheme(textLbl,"text","TextColor3")

    -- checkbox (14×14) on the left, after the label
    local toggleOut = create("TextButton",{
        Parent=labelFrame, Name="!toggle",
        Text="", AutoButtonColor=false,
        Position=dim2(0,0,0,2),
        Size=dim2(0,14,0,14), BorderSizePixel=0,
        ZIndex=1,
        BackgroundColor3=themes.preset.outline,
    })
    applyTheme(toggleOut,"outline","BackgroundColor3")

    local toggleIn = create("Frame",{
        Parent=toggleOut, Name="inline",
        Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
        BorderSizePixel=0, ZIndex=2,
        BackgroundColor3=themes.preset.inline,
    })
    applyTheme(toggleIn,"inline","BackgroundColor3")

    -- accent fill (shown when ON)
    local accentFill = create("Frame",{
        Parent=toggleIn, Name="background",
        BackgroundTransparency=default and 0 or 1,
        ZIndex=3,
        Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
        BorderSizePixel=0,
        BackgroundColor3=themes.preset.accent,
    })
    applyTheme(accentFill,"accent","BackgroundColor3")
    create("UIGradient",{
        Parent=accentFill, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,rgb(255,255,255)),
            ColorSequenceKeypoint.new(1,rgb(167,167,167)),
        }
    })

    -- inert background (always visible, sits under accent)
    local bgFill = create("Frame",{
        Parent=toggleIn, Name="background",
        ZIndex=2,
        Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
        BorderSizePixel=0,
        BackgroundColor3=rgb(255,255,255),
    })
    applyTheme(bgFill,"accent","BackgroundColor3")
    create("UIGradient",{
        Parent=bgFill, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1,themes.preset.high_contrast),
        }
    })
    applyTheme(bgFill:FindFirstChildOfClass("UIGradient"),"contrast","Color")

    -- hover overlay (hoverify: parented to toggleOut, ZIndex=1)
    local hoverOverlay = create("Frame",{
        Parent=toggleOut,
        BackgroundTransparency=1,
        Size=dim2(1,0,1,0),
        BorderSizePixel=0,
        BackgroundColor3=themes.preset.accent,
        ZIndex=1,
    })
    applyTheme(hoverOverlay,"accent","BackgroundColor3")

    -- ── Optional inline keybind badge in right_components ─────────────────────
    local curKey       = defaultKey
    local keyListening = false

    if defaultKey then
        local keyNames = {
            [Enum.KeyCode.LeftShift]="ls", [Enum.KeyCode.RightShift]="rs",
            [Enum.KeyCode.LeftControl]="lc", [Enum.KeyCode.RightControl]="rc",
            [Enum.KeyCode.LeftAlt]="la", [Enum.KeyCode.RightAlt]="ra",
            [Enum.KeyCode.Return]="ent", [Enum.KeyCode.Backspace]="bs",
            [Enum.KeyCode.CapsLock]="caps", [Enum.KeyCode.Insert]="ins",
        }
        local function keyName(k)
            return keyNames[k] or tostring(k.Name):lower()
        end

        -- kOut: fixed pixel size, no AutomaticSize to avoid circular layout
        local kOut = create("Frame",{
            Parent=right_components,
            Size=dim2(0,28,0,12), BorderSizePixel=0,
            BackgroundColor3=themes.preset.outline, ZIndex=2,
        })
        applyTheme(kOut,"outline","BackgroundColor3")

        local kIn = create("Frame",{
            Parent=kOut,
            Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
            BorderSizePixel=0, ZIndex=2,
            BackgroundColor3=themes.preset.inline,
        })
        applyTheme(kIn,"inline","BackgroundColor3")

        local kHandler = create("Frame",{
            Parent=kIn,
            Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
            BorderSizePixel=0, ZIndex=2,
            BackgroundColor3=rgb(255,255,255),
        })
        local kGrad = create("UIGradient",{
            Parent=kHandler, Rotation=90,
            Color=ColorSequence.new{
                ColorSequenceKeypoint.new(0,themes.preset.low_contrast),
                ColorSequenceKeypoint.new(1,themes.preset.high_contrast),
            }
        })
        applyTheme(kGrad,"contrast","Color")

        -- hover overlay sits inside kHandler at full size — no AutomaticSize conflict
        local kHover = create("Frame",{
            Parent=kHandler, BackgroundTransparency=1,
            Size=dim2(1,0,1,0), BorderSizePixel=0,
            BackgroundColor3=themes.preset.accent, ZIndex=4,
        })
        applyTheme(kHover,"accent","BackgroundColor3")

        local kText = create("TextLabel",{
            Parent=kHandler, FontFace=customFont,
            Text=keyName(defaultKey),
            TextColor3=themes.preset.text,
            BackgroundTransparency=1,
            Size=dim2(1,0,1,0), ZIndex=3,
            TextSize=12, TextXAlignment=Enum.TextXAlignment.Center,
            BorderSizePixel=0, BackgroundColor3=rgb(255,255,255),
        })
        applyTheme(kText,"text","TextColor3")

        kOut.MouseEnter:Connect(function() tween(kHover,{BackgroundTransparency=0.85}) end)
        kOut.MouseLeave:Connect(function() tween(kHover,{BackgroundTransparency=1}) end)

        -- left-click badge to rebind
        kOut.InputBegan:Connect(function(inp)
            if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
            if keyListening then return end
            keyListening = true
            kText.Text = "..."
            tween(kText,{TextColor3=themes.preset.accent})

            local rebindConn
            rebindConn = UserInputService.InputBegan:Connect(function(i, processed)
                if processed then return end
                if i.UserInputType ~= Enum.UserInputType.Keyboard then return end
                if i.KeyCode == Enum.KeyCode.Unknown then return end
                curKey = i.KeyCode
                kText.Text = keyName(curKey)
                tween(kText,{TextColor3=themes.preset.text})
                keyListening = false
                rebindConn:Disconnect()
            end)
        end)
    end
    -- ─────────────────────────────────────────────────────────────────────────

    local state = default
    local busy  = false

    local function setState(val)
        state = val
        tween(accentFill,{ BackgroundTransparency = val and 0 or 1 })
        safeCall(callback, val)
    end

    -- keybind activation — wired here so setState is in scope
    if defaultKey then
        conn(UserInputService.InputBegan, function(inp, processed)
            if processed or keyListening or not curKey then return end
            if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
            if inp.KeyCode == curKey then
                setState(not state)
            end
        end)
    end

    local function onClick()
        if busy then return end
        busy = true
        setState(not state)
        task.delay(0.15, function() busy=false end)
    end

    row.MouseButton1Click:Connect(onClick)
    toggleOut.MouseButton1Click:Connect(onClick)

    -- hover: listen on the whole row, glow the checkbox
    row.MouseEnter:Connect(function()
        tween(hoverOverlay,{BackgroundTransparency=0})
    end)
    row.MouseLeave:Connect(function()
        tween(hoverOverlay,{BackgroundTransparency=1})
    end)

    return row, function() return state end
end

-- ── Slider  (Skibid: flat fill bar, "cur/max" text overlay) ──────────────────
local function _makeSlider(parent, label, min, max, default, callback, order)
    assert(min < max, "[UILib] slider min must be < max: "..label)
    default = math.clamp(default, min, max)

    -- Skibid: root is TextLabel, Size=dim2(1,-8,0,12), AutomaticSize=Y
    local root = create("TextLabel",{
        Parent=parent, Name=label:gsub(" ","_"),
        FontFace=customFont, TextColor3=themes.preset.text,
        Text="", ZIndex=1,
        Size=dim2(1,-8,0,12), BorderSizePixel=0,
        BackgroundTransparency=1,
        TextXAlignment=Enum.TextXAlignment.Left,
        AutomaticSize=Enum.AutomaticSize.Y,
        TextYAlignment=Enum.TextYAlignment.Top,
        TextSize=12, BackgroundColor3=rgb(255,255,255),
        LayoutOrder=order or 0,
    })

    -- Skibid: left_components — label text created FIRST, then UIListLayout
    local leftComp = create("Frame",{
        Parent=root, Name="left_components",
        BackgroundTransparency=1,
        Position=dim2(0,2,0,-1),
        Size=dim2(0,0,0,14), BorderSizePixel=0,
        BackgroundColor3=rgb(255,255,255),
    })
    local nameLbl = create("TextLabel",{
        Parent=leftComp, FontFace=customFont,
        Text=label, TextColor3=themes.preset.text,
        Name="text",
        BackgroundTransparency=1, Size=dim2(0,0,1,-1),
        AutomaticSize=Enum.AutomaticSize.X,
        BorderSizePixel=0, TextSize=12,
        BackgroundColor3=rgb(255,255,255),
    })
    -- Skibid: UIListLayout on left_components comes AFTER the text label
    create("UIListLayout",{
        Parent=leftComp, Padding=dim(0,5),
        FillDirection=Enum.FillDirection.Horizontal,
    })

    -- Skibid: bottom_components — Size=dim2(1,0,0,0), no AutomaticSize
    local bottomComp = create("Frame",{
        Parent=root, Name="bottom_components",
        Position=dim2(0,0,0,15),
        Size=dim2(1,0,0,0), BorderSizePixel=0,
        BackgroundColor3=rgb(255,255,255),
    })

    -- Skibid: slider TextButton (= outline), Name="slider"
    local sliderBtn = create("TextButton",{
        Parent=bottomComp, Name="slider",
        Position=dim2(0,0,0,2),
        Size=dim2(1,-1,1,12), BorderSizePixel=0,
        BackgroundColor3=themes.preset.outline,
        Text="", AutoButtonColor=false,
    })
    applyTheme(sliderBtn,"outline","BackgroundColor3")

    -- Skibid: hoverify(slider_REAL, slider) — created IMMEDIATELY after slider, before inline
    local sliderHover = create("Frame",{
        Parent=sliderBtn,
        BackgroundTransparency=1,
        Size=dim2(1,0,1,0), BorderSizePixel=0,
        BackgroundColor3=themes.preset.accent,
        ZIndex=1,
    })
    applyTheme(sliderHover,"accent","BackgroundColor3")

    -- Skibid: inline frame inside slider
    local sliderIn = create("Frame",{
        Parent=sliderBtn, Name="inline",
        Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
        BorderSizePixel=0, ZIndex=1,
        BackgroundColor3=themes.preset.inline,
    })
    applyTheme(sliderIn,"inline","BackgroundColor3")

    -- Skibid: background frame inside inline — no BackgroundColor3 set (defaults white)
    local sliderBg = create("Frame",{
        Parent=sliderIn, Name="background",
        Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
        BorderSizePixel=0,
    })

    -- Skibid: contrast frame inside background — white bg
    local contrast = create("Frame",{
        Parent=sliderBg, Name="contrast",
        Size=dim2(1,0,1,0), BorderSizePixel=0,
        BackgroundColor3=rgb(255,255,255),
    })

    -- Skibid: slidertext created FIRST inside contrast (ZIndex=2)
    local sliderText = create("TextLabel",{
        Parent=contrast, FontFace=customFont,
        TextColor3=themes.preset.text,
        Text=tostring(default).."/"..tostring(max),
        Name="text", BackgroundTransparency=1,
        Position=dim2(0,0,0,-1), Size=dim2(1,0,1,0),
        BorderSizePixel=0, TextSize=12, ZIndex=2,
        BackgroundColor3=rgb(255,255,255),
    })
    applyTheme(sliderText,"text","TextColor3")

    -- Skibid: fill created AFTER slidertext — starts at full size (set via setValue)
    local fill = create("Frame",{
        Parent=contrast, Name="fill",
        Size=dim2(1,0,1,0), BorderSizePixel=0,
        BackgroundColor3=themes.preset.accent,
    })
    applyTheme(fill,"accent","BackgroundColor3")

    -- Skibid: fill gradient (white→grey) on fill
    create("UIGradient",{
        Parent=fill, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,rgb(255,255,255)),
            ColorSequenceKeypoint.new(1,rgb(167,167,167)),
        }
    })

    -- Skibid: contrast gradient (dark, apply_theme) on contrast — AFTER fill
    local contrastGrad = create("UIGradient",{
        Parent=contrast, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1,themes.preset.high_contrast),
        }
    })
    applyTheme(contrastGrad,"contrast","Color")

    -- Skibid: background gradient (white→grey, no apply_theme) on background — AFTER contrast
    create("UIGradient",{
        Parent=sliderBg, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,rgb(255,255,255)),
            ColorSequenceKeypoint.new(1,rgb(167,167,167)),
        }
    })

    -- Skibid: UIListLayout on bottom_components placed LAST, after all slider children
    create("UIListLayout",{
        Parent=bottomComp, Padding=dim(0,10),
        SortOrder=Enum.SortOrder.LayoutOrder,
    })

    local cur      = default
    local dragging = false

    local function round(v, interval)
        return math.floor(v / interval + 0.5) * interval
    end

    local function setValue(raw)
        local ratio = math.clamp((raw - sliderBtn.AbsolutePosition.X) / sliderBtn.AbsoluteSize.X, 0, 1)
        local v = round(min + (max - min) * ratio, 1)
        v = math.clamp(v, min, max)
        cur = v
        fill.Size = dim2((v - min) / (max - min), 0, 1, 0)
        sliderText.Text = tostring(v) .. "/" .. tostring(max)
        safeCall(callback, v)
    end

    sliderBtn.MouseButton1Down:Connect(function()
        dragging = true
    end)
    conn(UserInputService.InputEnded, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    conn(UserInputService.InputChanged, function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            setValue(inp.Position.X)
        end
    end)

    -- Skibid: hoverify tweens the overlay on slider, triggered by root (slider_REAL)
    root.MouseEnter:Connect(function()
        tween(sliderHover,{BackgroundTransparency=0})
    end)
    root.MouseLeave:Connect(function()
        tween(sliderHover,{BackgroundTransparency=1})
    end)

    -- Set correct initial fill width (Skibid: cfg.set(cfg.default) at end)
    fill.Size = dim2((default - min) / (max - min), 0, 1, 0)
    sliderText.Text = tostring(default) .. "/" .. tostring(max)

    return root, function() return cur end
end

-- ── Dropdown  (Skibid: outline→inline→bg with +/- indicator, floating holder) ─
local function _makeDropdown(parent, label, items, default, callback, order)
    items = items or {}
    default = default or items[1] or ""

    local openState = false
    local selectedValue = default
    local optionInstances = {}

    -- root wrapper
