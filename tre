    })
    applyTheme(hexBox,"accent","TextColor3")

    local cur = default
    hexBox.FocusLost:Connect(function(enterPressed)
        local raw = hexBox.Text:gsub("#","")
        if #raw==6 and raw:match("^%x+$") then
            cur = hex("#"..raw)
            swatch.BackgroundColor3 = cur
            hexBox.Text = "#"..raw:upper()
            if enterPressed then safeCall(callback, cur) end
        else
            hexBox.Text = "#"..cur:ToHex():upper()
        end
    end)

    return card, function() return cur end
end

