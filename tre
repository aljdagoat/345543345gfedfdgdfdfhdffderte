    create("TextLabel",{
        Parent=secBg, FontFace=customFont, Text=title,
        TextColor3=themes.preset.text, BackgroundTransparency=1,
        Position=dim2(0,6,0,4), BorderSizePixel=0,
        AutomaticSize=Enum.AutomaticSize.XY, TextSize=12,
        BackgroundColor3=rgb(255,255,255),
    })
    local accentBar = create("Frame",{
        Parent=secBg, Size=dim2(1,0,0,2), BorderSizePixel=0,
        BackgroundColor3=themes.preset.accent,
    })
    applyTheme(accentBar,"accent","BackgroundColor3")
    create("UIGradient",{ Parent=accentBar, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,rgb(255,255,255)),
            ColorSequenceKeypoint.new(1,rgb(167,167,167)),
