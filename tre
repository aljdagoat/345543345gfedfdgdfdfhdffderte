        BorderColor3=rgb(0,0,0), Size=dim2(0,4,1,0), BackgroundColor3=rgb(255,255,255),
    })

    local function setColor(newColor, newAlpha)
        if newColor then h,s,v=newColor:ToHSV() end
        if newAlpha then a=newAlpha end
        local Color = Color3.fromHSV(h,s,v)
        local hOffset = (1-h < 1) and 0 or -4
        huePicker.Position = dim2(0,0,1-h,hOffset)
        local aOffset = (a < 1) and 0 or -4
        alphaPicker.Position = dim2(a,aOffset,0,0)
        alphaDrag.BackgroundColor3=Color; visualize.BackgroundColor3=Color
        cpBtnHandler.BackgroundColor3=Color; colorpicker.BackgroundColor3=Color3.fromHSV(h,1,1)
        cpHexLbl.Text="#"..Color:ToHex():upper()
        local sOff=-1; local vOff=-1
        if s >= 1 then sOff=-3 end; if (1-v) >= 1 then vOff=-3 end
        svREAL.Position = dim2(s,sOff,1-v,vOff)
        safeCall(callback, Color, a)
    end
    local function updateColor(mouse)
        if dragging_sat then
            s=math.clamp((mouse.X-val.AbsolutePosition.X)/val.AbsoluteSize.X,0,1)
            v=1-math.clamp((mouse.Y-sat.AbsolutePosition.Y)/sat.AbsoluteSize.Y,0,1)
        elseif dragging_hue then
            h=math.clamp(1-(mouse.Y-hueBtn.AbsolutePosition.Y)/hueBtn.AbsoluteSize.Y,0,1)
        elseif dragging_alpha then
            a=math.clamp((mouse.X-alphaBtn.AbsolutePosition.X)/alphaBtn.AbsoluteSize.X,0,1)
        end
        setColor(nil,nil)
    end
    sat.MouseButton1Down:Connect(function() dragging_sat=true end)
    hueBtn.MouseButton1Down:Connect(function() dragging_hue=true end)
    alphaBtn.MouseButton1Down:Connect(function() dragging_alpha=true end)
    conn(UserInputService.InputEnded, function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging_sat=false; dragging_hue=false; dragging_alpha=false
        end
    end)
    conn(UserInputService.InputChanged, function(inp)
        if (dragging_sat or dragging_hue or dragging_alpha)
            and inp.UserInputType==Enum.UserInputType.MouseMovement then
            updateColor(inp.Position)
        end
    end)
    local function cpFadeClose(frame, onDone)
        tween(frame,{GroupTransparency=1},0.18)
        task.delay(0.18, function()
            if frame and frame.Parent then
                frame.Visible=false; frame.GroupTransparency=0
            end
            if onDone then onDone() end
        end)
    end
    _ensurePopupListeners()
    cpBtn.MouseButton1Click:Connect(function()
        if open then
            open=false; _unregisterPopup(cpHolder); cpFadeClose(cpHolder)
        else
            open=true
            cpHolder.Position=dim2(0,cpBtn.AbsolutePosition.X+1,0,cpBtn.AbsolutePosition.Y+17)
            cpHolder.GroupTransparency=1; cpHolder.Size=UDim2.new(0,190,0,210)
            cpHolder.Visible=true; tween(cpHolder,{GroupTransparency=0},0.18)
            _registerPopup(cpHolder, function() open=false end, cpFadeClose)
        end
    end)
    setColor(default,1)

    local getter = function() return Color3.fromHSV(h,s,v), a end
    local setter = function(col)
        if col then h,s,v=col:ToHSV() end
        setColor(nil,nil)
    end
    return getter, setter
end

