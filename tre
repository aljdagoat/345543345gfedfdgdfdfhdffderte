-- addColumn: Skibid library:column() — creates side-by-side columns with horizontal flex.
-- First call lazy-creates a shared row frame. Each call adds a new column into it.
-- Usage:
--   local left  = tab:addColumn()
--   local right = tab:addColumn()
--   left:addSection("Aimbot")
--   right:addSection("Visuals")
function TabAPI:addColumn()
    if not self._colRow then
        self._colRow = create("Frame",{
            Parent=self._c,
            Name="column_row",
            Size=dim2(1,0,0,0),
            AutomaticSize=Enum.AutomaticSize.Y,
            BackgroundTransparency=1,
            BorderSizePixel=0,
            LayoutOrder=self._i,
        })
        create("UIListLayout",{
            Parent=self._colRow,
            FillDirection=Enum.FillDirection.Horizontal,
            HorizontalFlex=Enum.UIFlexAlignment.Fill,
            VerticalAlignment=Enum.VerticalAlignment.Top,
            Padding=dim(0,4),
            SortOrder=Enum.SortOrder.LayoutOrder,
        })
        self._i = self._i + 1
        self._colCount = 0
    end

    self._colCount = self._colCount + 1

    -- Skibid: column frame Size=dim2(0.5,-6,0,0), AutomaticSize=Y
    local col = create("Frame",{
        Parent=self._colRow,
        Name="column_"..self._colCount,
        Size=dim2(0.5,-6,0,0),
        AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundTransparency=1,
        BorderSizePixel=0,
        LayoutOrder=self._colCount,
    })
    -- Skibid: column UIListLayout Padding=dim(0,4), VerticalFlex=Fill
    create("UIListLayout",{
        Parent=col,
        Padding=dim(0,4),
        SortOrder=Enum.SortOrder.LayoutOrder,
        VerticalFlex=Enum.UIFlexAlignment.Fill,
    })

    -- Return TabAPI-compatible so addSection works identically on columns
    return setmetatable({ _c=col, _i=1 }, TabAPI)
end

-- ── WindowAPI ────────────────────────────────────────────────────────────────
local WindowAPI = {}
WindowAPI.__index = WindowAPI

function WindowAPI:_switchTab(name)
    for n, data in pairs(self._tabs) do
        data.indicator.Visible = (n==name)
        data.content.Visible   = (n==name)
        tween(data.button,{ TextColor3 = n==name and themes.preset.accent or themes.preset.text })
    end
end

function WindowAPI:addTab(name)
    local content, container
    if name=="Players" then
        content = _buildPlayersTab(self._ch)
    else
        content, container = _makeScrollContent(self._ch)
    end
    local btn, ind = self._mkBtn(name, self._to)
    self._to = self._to + 1
    self._tabs[name] = { button=btn, indicator=ind, content=content }
    btn.MouseButton1Click:Connect(function() self:_switchTab(name) end)
    if not self._firstTab then self._firstTab=name; self:_switchTab(name) end
    if name=="Players" then return nil end
    return setmetatable({ _c=container, _i=1 }, TabAPI)
end

function WindowAPI:addThemeTab()
    local content, container = _makeScrollContent(self._ch)
    local lbl = create("TextLabel",{ Parent=container, FontFace=customFont,
        Text="Theme Customization", TextColor3=themes.preset.accent,
        BackgroundTransparency=1, Size=dim2(1,0,0,16),
        TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, LayoutOrder=1 })
    applyTheme(lbl,"accent","TextColor3")
    _makeThemeColorPicker(container,"Outline",       "outline",       10)
    _makeThemeColorPicker(container,"Inline",        "inline",        11)
    _makeThemeColorPicker(container,"Accent",        "accent",        12)
    _makeThemeColorPicker(container,"High Contrast", "high_contrast", 13)
    _makeThemeColorPicker(container,"Low Contrast",  "low_contrast",  14)
    _makeThemeColorPicker(container,"Text",          "text",          15)
    _makeThemeColorPicker(container,"Glow",          "glow",          16)
    local btn, ind = self._mkBtn("Theme", self._to); self._to = self._to + 1
    self._tabs["Theme"] = { button=btn, indicator=ind, content=content }
    btn.MouseButton1Click:Connect(function() self:_switchTab("Theme") end)
    if not self._firstTab then self._firstTab="Theme"; self:_switchTab("Theme") end
end

function WindowAPI:destroy()
    self._gui:Destroy()
    for _,c in pairs(connections) do c:Disconnect() end
    connections = {}
end

