-- ── Window / library API ───────────────────────────────────────────────────────
local WindowAPI = {}
WindowAPI.__index = WindowAPI

function WindowAPI:addTab(name)
    -- Special handling for Players tab
    if name == "Players" then
        local content = _buildPlayersTab(self._contentHolder)
        local btn, indicator = self._createTabBtn(name, self._tabOrder)
        self._tabOrder = self._tabOrder + 1
        self._tabs[name] = { button = btn, indicator = indicator, content = content }
        btn.MouseButton1Click:Connect(function() self:_switchTab(name) end)
        return nil -- Players tab manages itself
    end

    -- Generic scrollable tab
    local content, container = _makeScrollContent(self._contentHolder)
    local btn, indicator = self._createTabBtn(name, self._tabOrder)
    self._tabOrder = self._tabOrder + 1
    self._tabs[name] = { button = btn, indicator = indicator, content = content }
    btn.MouseButton1Click:Connect(function() self:_switchTab(name) end)

    local tab = setmetatable({ _container = container, _sectionOrder = 1 }, TabAPI)
    return tab
end

function WindowAPI:_switchTab(tabName)
    for name, data in pairs(self._tabs) do
        data.indicator.Visible = (name == tabName)
        data.content.Visible  = (name == tabName)
        if name == tabName then
            tween(data.button, { TextColor3 = themes.preset.accent })
        else
            tween(data.button, { TextColor3 = themes.preset.text })
        end
    end
end

function WindowAPI:destroy()
    self._screenGui:Destroy()
    for _, c in pairs(connections) do c:Disconnect() end
    connections = {}
end

