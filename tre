-- ── Toggle ────────────────────────────────────────────────────────────────────
local function _makeToggle(parent, label, default, callback, order, defaultKey)
    assert(type(default)=="boolean","[UILib] toggle default must be boolean: "..label)
    local row = create("TextButton",{
        Parent=parent, Name=label:gsub(" ","_"),
        Size=dim2(1,-8,0,12), BorderSizePixel=0, BackgroundTransparency=1,
        Text="", AutoButtonColor=false, TextXAlignment=Enum.TextXAlignment.Left,
        AutomaticSize=Enum.AutomaticSize.Y, TextYAlignment=Enum.TextYAlignment.Top,
        FontFace=customFont, TextSize=12, TextColor3=themes.preset.text,
        LayoutOrder=order or 0, ZIndex=1,
    })
    local right_components = create("Frame",{
        Parent=row, Name="right_components",
        AnchorPoint=vec2(1,0.5), Position=dim2(1,-1,0.5,0),
        Size=dim2(0,0,0,14), BorderSizePixel=0,
        AutomaticSize=Enum.AutomaticSize.X, BackgroundTransparency=1,
        BackgroundColor3=rgb(255,255,255),
    })
    create("UIListLayout",{ Parent=right_components,
        VerticalAlignment=Enum.VerticalAlignment.Center,
        FillDirection=Enum.FillDirection.Horizontal,
        HorizontalAlignment=Enum.HorizontalAlignment.Right,
        Padding=dim(0,4), SortOrder=Enum.SortOrder.LayoutOrder })
    create("UIPadding",{ Parent=row })
    local labelFrame = create("Frame",{
        Parent=row, Name="left_components", BackgroundTransparency=1,
        Position=dim2(0,0,0,0), Size=dim2(0,0,0,14), BorderSizePixel=0,
        BackgroundColor3=rgb(255,255,255),
    })
    create("UIListLayout",{ Parent=labelFrame, Padding=dim(0,5),
        FillDirection=Enum.FillDirection.Horizontal })
    local textLbl = create("TextLabel",{
        Parent=labelFrame, FontFace=customFont, Text=label,
        TextColor3=themes.preset.text, BackgroundTransparency=1,
        Size=dim2(0,0,1,-1), AutomaticSize=Enum.AutomaticSize.X,
        BorderSizePixel=0, TextSize=12, BackgroundColor3=rgb(255,255,255),
    })
    applyTheme(textLbl,"text","TextColor3")
    local toggleOut = create("TextButton",{
        Parent=labelFrame, Name="!toggle", Text="", AutoButtonColor=false,
        Position=dim2(0,0,0,2), Size=dim2(0,14,0,14), BorderSizePixel=0,
        ZIndex=1, BackgroundColor3=themes.preset.outline,
    })
    applyTheme(toggleOut,"outline","BackgroundColor3")
    local toggleIn = create("Frame",{
        Parent=toggleOut, Name="inline", Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
        BorderSizePixel=0, ZIndex=2, BackgroundColor3=themes.preset.inline,
    })
    applyTheme(toggleIn,"inline","BackgroundColor3")
    local accentFill = create("Frame",{
        Parent=toggleIn, Name="background",
        BackgroundTransparency=default and 0 or 1, ZIndex=3,
        Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2), BorderSizePixel=0,
        BackgroundColor3=themes.preset.accent,
    })
    applyTheme(accentFill,"accent","BackgroundColor3")
    create("UIGradient",{ Parent=accentFill, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,rgb(255,255,255)),
            ColorSequenceKeypoint.new(1,rgb(167,167,167)),
        }})
    local bgFill = create("Frame",{
        Parent=toggleIn, Name="background", ZIndex=2,
        Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2), BorderSizePixel=0,
        BackgroundColor3=rgb(255,255,255),
    })
    applyTheme(bgFill,"accent","BackgroundColor3")
    local bgFillGrad = create("UIGradient",{ Parent=bgFill, Rotation=90,
        Color=ColorSequence.new{
            ColorSequenceKeypoint.new(0,themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1,themes.preset.high_contrast),
        }})
    applyTheme(bgFillGrad,"contrast","Color")
    local hoverOverlay = create("Frame",{
        Parent=toggleOut, BackgroundTransparency=1,
        Size=dim2(1,0,1,0), BorderSizePixel=0,
        BackgroundColor3=themes.preset.accent, ZIndex=1,
    })
    applyTheme(hoverOverlay,"accent","BackgroundColor3")

    -- optional inline keybind badge
    local curKey = defaultKey; local keyListening = false
    if defaultKey then
        local keyNames = {
            [Enum.KeyCode.LeftShift]="ls",[Enum.KeyCode.RightShift]="rs",
            [Enum.KeyCode.LeftControl]="lc",[Enum.KeyCode.RightControl]="rc",
            [Enum.KeyCode.LeftAlt]="la",[Enum.KeyCode.RightAlt]="ra",
            [Enum.KeyCode.Return]="ent",[Enum.KeyCode.Backspace]="bs",
            [Enum.KeyCode.CapsLock]="caps",[Enum.KeyCode.Insert]="ins",
        }
        local function keyName(k) return keyNames[k] or tostring(k.Name):lower() end
        local kOut = create("Frame",{
            Parent=right_components, AnchorPoint=vec2(0,0.5),
            Size=dim2(0,22,0,14), BorderSizePixel=0,
            BackgroundColor3=themes.preset.outline, ZIndex=2,
        })
        applyTheme(kOut,"outline","BackgroundColor3")
        local kIn = create("Frame",{
            Parent=kOut, Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
            BorderSizePixel=0, ZIndex=2, BackgroundColor3=themes.preset.inline,
        })
        applyTheme(kIn,"inline","BackgroundColor3")
        local kHandler = create("Frame",{
            Parent=kIn, Position=dim2(0,1,0,1), Size=dim2(1,-2,1,-2),
            BorderSizePixel=0, ZIndex=2, BackgroundColor3=rgb(255,255,255),
        })
        local kGrad = create("UIGradient",{ Parent=kHandler, Rotation=90,
            Color=ColorSequence.new{
                ColorSequenceKeypoint.new(0,themes.preset.low_contrast),
                ColorSequenceKeypoint.new(1,themes.preset.high_contrast),
            }})
        applyTheme(kGrad,"contrast","Color")
        local kHover = create("Frame",{
            Parent=kHandler, BackgroundTransparency=1,
            Size=dim2(1,0,1,0), BorderSizePixel=0,
            BackgroundColor3=themes.preset.accent, ZIndex=4,
        })
        applyTheme(kHover,"accent","BackgroundColor3")
        local kText = create("TextLabel",{
            Parent=kHandler, FontFace=customFont, Text=keyName(defaultKey),
            TextColor3=themes.preset.text, BackgroundTransparency=1,
            Size=dim2(1,0,1,0), ZIndex=3, Position=dim2(0,0,0,-1),
            TextSize=12, TextXAlignment=Enum.TextXAlignment.Center,
            TextYAlignment=Enum.TextYAlignment.Center,
            BorderSizePixel=0, BackgroundColor3=rgb(255,255,255),
        })
        applyTheme(kText,"text","TextColor3")
        kOut.MouseEnter:Connect(function() tween(kHover,{BackgroundTransparency=0.85}) end)
        kOut.MouseLeave:Connect(function() tween(kHover,{BackgroundTransparency=1}) end)
        kOut.InputBegan:Connect(function(inp)
            if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
            if keyListening then return end
            _ensurePopupListeners()
            keyListening=true; kText.Text="..."
            tween(kText,{TextColor3=themes.preset.accent})
            _registerPopup(kOut, function()
                if keyListening then
                    keyListening=false; kText.Text=keyName(curKey)
                    tween(kText,{TextColor3=themes.preset.text})
                end
            end)
            local rebindConn
            rebindConn = UserInputService.InputBegan:Connect(function(i,processed)
                if processed then return end
                if i.KeyCode==Enum.KeyCode.Escape then
                    keyListening=false; kText.Text=keyName(curKey)
                    tween(kText,{TextColor3=themes.preset.text})
                    _unregisterPopup(kOut); rebindConn:Disconnect(); return
                end
                if i.UserInputType~=Enum.UserInputType.Keyboard then return end
                if i.KeyCode==Enum.KeyCode.Unknown then return end
                curKey=i.KeyCode; kText.Text=keyName(curKey)
                tween(kText,{TextColor3=themes.preset.text})
                keyListening=false; _unregisterPopup(kOut); rebindConn:Disconnect()
            end)
        end)
    end

    local state = default; local busy = false
    local function setState(val)
        state=val
        tween(accentFill,{ BackgroundTransparency = val and 0 or 1 })
        safeCall(callback, val)
    end
    if defaultKey then
        conn(UserInputService.InputBegan, function(inp,processed)
            if processed or keyListening or not curKey then return end
            if inp.UserInputType~=Enum.UserInputType.Keyboard then return end
            if inp.KeyCode==curKey then setState(not state) end
        end)
    end
    local function onClick()
        if busy then return end; busy=true; setState(not state)
        task.delay(0.15, function() busy=false end)
    end
    row.MouseButton1Click:Connect(onClick)
    toggleOut.MouseButton1Click:Connect(onClick)
    row.MouseEnter:Connect(function() tween(hoverOverlay,{BackgroundTransparency=0}) end)
    row.MouseLeave:Connect(function() tween(hoverOverlay,{BackgroundTransparency=1}) end)

    local toggleAPI = {}; toggleAPI.__index = toggleAPI
    function toggleAPI:addColorPicker(color, cb)
        _makeColorPickerBadge(right_components, color, cb)
        return self
    end
    setmetatable(toggleAPI, { __call = function() return state end })

    local getter = function() return state end
    local setter = function(val) setState(val == true) end
    return row, getter, setter
end

