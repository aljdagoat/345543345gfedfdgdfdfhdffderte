-- ── Helpers ───────────────────────────────────────────────────────────────────
local function tween(obj, properties)
    local tw = TweenService:Create(obj, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), properties)
    tw:Play()
    return tw
end

local function applyTheme(instance, theme, property)
    if not themes.utility[theme] then return end
    if not themes.utility[theme][property] then return end
    table.insert(themes.utility[theme][property], instance)
end

local function create(instanceType, properties)
    local instance = Instance.new(instanceType)
    for prop, value in pairs(properties) do
        instance[prop] = value
    end
    if instanceType == "TextLabel" or instanceType == "TextButton" or instanceType == "TextBox" then
        applyTheme(instance, "text", "TextColor3")
        local stroke = Instance.new("UIStroke")
        stroke.Parent = instance
        stroke.Color = themes.preset.text_outline
        stroke.LineJoinMode = Enum.LineJoinMode.Miter
        applyTheme(stroke, "text_outline", "Color")
    end
    return instance
end

local function updateTheme()
    for themeName, properties in pairs(themes.utility) do
        for propertyName, instances in pairs(properties) do
            for _, instance in pairs(instances) do
                if instance and instance.Parent then
                    if themeName == "contrast" then
                        instance[propertyName] = ColorSequence.new{
                            ColorSequenceKeypoint.new(0, themes.preset.low_contrast),
                            ColorSequenceKeypoint.new(1, themes.preset.high_contrast)
                        }
                    elseif themes.preset[themeName] then
                        instance[propertyName] = themes.preset[themeName]
                    end
                end
            end
        end
    end
end

-- dragHandle = the region you click to drag; frame = the window being moved
local function makeDraggable(frame, dragHandle)
    dragHandle = dragHandle or frame
    local dragging, startPos, startFramePos = false, nil, nil
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            startPos = input.Position
            startFramePos = frame.Position
        end
    end)
    dragHandle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    local c = UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local vp = Camera.ViewportSize
            frame.Position = dim2(
                0, math.clamp(startFramePos.X.Offset + (input.Position.X - startPos.X), 0, vp.X - frame.Size.X.Offset),
                0, math.clamp(startFramePos.Y.Offset + (input.Position.Y - startPos.Y), 0, vp.Y - frame.Size.Y.Offset)
            )
        end
    end)
    table.insert(connections, c)
end

local function makeResizable(frame)
    local resizeFrame = Instance.new("TextButton")
    resizeFrame.Position = dim2(1, -10, 1, -10)
    resizeFrame.Size = dim2(0, 10, 0, 10)
    resizeFrame.BackgroundTransparency = 1
    resizeFrame.Text = ""
    resizeFrame.Parent = frame

    local resizing, startSize, startPos = false, nil, nil
    local originalSize = frame.Size

    resizeFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = true
            startPos = input.Position
            startSize = frame.Size
        end
    end)
    resizeFrame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = false
        end
    end)
    local c = UserInputService.InputChanged:Connect(function(input)
        if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
            local vp = Camera.ViewportSize
            frame.Size = dim2(
                startSize.X.Scale, math.clamp(startSize.X.Offset + (input.Position.X - startPos.X), originalSize.X.Offset, vp.X),
                startSize.Y.Scale, math.clamp(startSize.Y.Offset + (input.Position.Y - startPos.Y), originalSize.Y.Offset, vp.Y)
            )
        end
    end)
    table.insert(connections, c)
end

