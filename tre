local function _makeSection(parent, title, order)
    local section = create("Frame", {
        Parent = parent, Name = title:gsub(" ", "_"),
        Size = dim2(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1, BorderSizePixel = 0, LayoutOrder = order
    })
    local sectionTitle = create("TextLabel", {
        Parent = section, FontFace = customFont, Text = title,
        TextColor3 = themes.preset.accent, BackgroundTransparency = 1,
        Size = dim2(1, 0, 0, 16), TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left
    })
    applyTheme(sectionTitle, "accent", "TextColor3")
    local content = create("Frame", {
        Parent = section, Name = "content", Position = dim2(0, 0, 0, 18),
        Size = dim2(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1, BorderSizePixel = 0
    })
    create("UIListLayout", { Parent = content, Padding = dim(0, 4), SortOrder = Enum.SortOrder.LayoutOrder })
    return content
end

local function _makeToggle(parent, label, defaultValue, callback, order)
    local cardOutline = create("Frame", {
        Parent = parent, Name = label:gsub(" ", "_"),
        Size = dim2(1, 0, 0, 26), BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.outline, LayoutOrder = order or 0
    })
    applyTheme(cardOutline, "outline", "BackgroundColor3")

    local cardInline = create("Frame", {
        Parent = cardOutline, Position = dim2(0, 1, 0, 1),
        Size = dim2(1, -2, 1, -2), BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.inline
    })
    applyTheme(cardInline, "inline", "BackgroundColor3")

    local cardHolder = create("Frame", {
        Parent = cardInline, Position = dim2(0, 1, 0, 1),
        Size = dim2(1, -2, 1, -2), BorderSizePixel = 0,
        BackgroundColor3 = rgb(255, 255, 255)
    })
    local cardGradient = create("UIGradient", {
        Parent = cardHolder, Rotation = 90,
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1, themes.preset.high_contrast)
        }
    })
    applyTheme(cardGradient, "contrast", "Color")
    create("UIPadding", {
        Parent = cardHolder,
        PaddingLeft = dim(0, 7), PaddingRight = dim(0, 7),
    })

    -- Accent left-edge bar — parented to cardInline so it spans the full card height regardless of padding
    local accentBar = create("Frame", {
        Parent = cardInline, Size = dim2(0, 2, 1, 0), Position = dim2(0, 0, 0, 0),
        BackgroundColor3 = themes.preset.accent, BorderSizePixel = 0, ZIndex = 5,
        BackgroundTransparency = defaultValue and 0 or 1
    })
    applyTheme(accentBar, "accent", "BackgroundColor3")

    -- Label
    create("TextLabel", {
        Parent = cardHolder, FontFace = customFont, Text = label,
        TextColor3 = themes.preset.text, BackgroundTransparency = 1,
        Position = dim2(0, 0, 0, 0), Size = dim2(1, -24, 1, 0),
        TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left
    })

    -- Square checkbox: outline → inner fill
    local BOX = 12
    local boxOutline = create("Frame", {
        Parent = cardHolder,
        AnchorPoint = vec2(1, 0.5),
        Position = dim2(1, 0, 0.5, 0),
        Size = dim2(0, BOX + 2, 0, BOX + 2),
        BackgroundColor3 = themes.preset.outline, BorderSizePixel = 0
    })
    applyTheme(boxOutline, "outline", "BackgroundColor3")

    local boxInner = create("Frame", {
        Parent = boxOutline, Position = dim2(0, 1, 0, 1),
        Size = dim2(1, -2, 1, -2), BorderSizePixel = 0,
        BackgroundColor3 = defaultValue and themes.preset.accent or themes.preset.high_contrast
    })
    if defaultValue then applyTheme(boxInner, "accent", "BackgroundColor3") end

    -- Click button over whole card
    local clickBtn = create("TextButton", {
        Parent = cardHolder, Size = dim2(1, 0, 1, 0),
        BackgroundTransparency = 1, Text = "",
        BorderSizePixel = 0, AutoButtonColor = false, ZIndex = 10
    })

    -- White overlay for hover — tweens transparency, no gradient conflict
    local hoverOverlay = Instance.new("Frame")
    hoverOverlay.Size = dim2(1, 0, 1, 0)
    hoverOverlay.BackgroundColor3 = rgb(255, 255, 255)
    hoverOverlay.BackgroundTransparency = 1
    hoverOverlay.BorderSizePixel = 0
    hoverOverlay.ZIndex = 9
    hoverOverlay.Parent = cardHolder

    local isEnabled = defaultValue
    clickBtn.MouseButton1Click:Connect(function()
        isEnabled = not isEnabled
        tween(boxInner,  { BackgroundColor3 = isEnabled and themes.preset.accent or themes.preset.high_contrast })
        tween(accentBar, { BackgroundTransparency = isEnabled and 0 or 1 })
        if callback then callback(isEnabled) end
    end)
    clickBtn.MouseEnter:Connect(function()
        tween(hoverOverlay, { BackgroundTransparency = 0.88 })
    end)
    clickBtn.MouseLeave:Connect(function()
        tween(hoverOverlay, { BackgroundTransparency = 1 })
    end)

    return cardOutline, function() return isEnabled end
end

local function _makeSlider(parent, label, min, max, default, callback, order)
    local cardOutline = create("Frame", {
        Parent = parent, Name = label:gsub(" ", "_"),
        Size = dim2(1, 0, 0, 38), BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.outline, LayoutOrder = order or 0
    })
    applyTheme(cardOutline, "outline", "BackgroundColor3")

    local cardInline = create("Frame", {
        Parent = cardOutline, Position = dim2(0, 1, 0, 1),
        Size = dim2(1, -2, 1, -2), BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.inline
    })
    applyTheme(cardInline, "inline", "BackgroundColor3")

    local cardHolder = create("Frame", {
        Parent = cardInline, Position = dim2(0, 1, 0, 1),
        Size = dim2(1, -2, 1, -2), BorderSizePixel = 0,
        BackgroundColor3 = rgb(255, 255, 255)
    })
    local cardGradient = create("UIGradient", {
        Parent = cardHolder, Rotation = 90,
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1, themes.preset.high_contrast)
        }
    })
    applyTheme(cardGradient, "contrast", "Color")
    create("UIPadding", {
        Parent = cardHolder,
        PaddingLeft = dim(0, 7), PaddingRight = dim(0, 7),
        PaddingTop = dim(0, 5), PaddingBottom = dim(0, 5)
    })

    -- Accent left-edge bar — parented to cardInline, spans full card height
    local accentBar = create("Frame", {
        Parent = cardInline, Size = dim2(0, 2, 1, 0), Position = dim2(0, 0, 0, 0),
        BackgroundColor3 = themes.preset.accent, BorderSizePixel = 0, ZIndex = 5
    })
    applyTheme(accentBar, "accent", "BackgroundColor3")

    -- Top row: label on left, value badge on right
    local topRow = create("Frame", {
        Parent = cardHolder, Size = dim2(1, 0, 0, 13),
        BackgroundTransparency = 1, BorderSizePixel = 0
    })

    create("TextLabel", {
        Parent = topRow, FontFace = customFont, Text = label,
        TextColor3 = themes.preset.text, BackgroundTransparency = 1,
        Size = dim2(1, -42, 1, 0), TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    -- Value badge: outline → inline → gradient holder
    local valOutline = create("Frame", {
        Parent = topRow, AnchorPoint = vec2(1, 0.5),
        Position = dim2(1, 0, 0.5, 0), Size = dim2(0, 40, 0, 13),
        BackgroundColor3 = themes.preset.outline, BorderSizePixel = 0
    })
    applyTheme(valOutline, "outline", "BackgroundColor3")
    local valInline = create("Frame", {
        Parent = valOutline, Position = dim2(0, 1, 0, 1),
        Size = dim2(1, -2, 1, -2), BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.inline
    })
    applyTheme(valInline, "inline", "BackgroundColor3")
    local valHolder = create("Frame", {
        Parent = valInline, Position = dim2(0, 1, 0, 1),
        Size = dim2(1, -2, 1, -2), BorderSizePixel = 0,
        BackgroundColor3 = rgb(255, 255, 255)
    })
    local valGrad = create("UIGradient", {
        Parent = valHolder, Rotation = 90,
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, themes.preset.low_contrast),
            ColorSequenceKeypoint.new(1, themes.preset.high_contrast)
        }
    })
    applyTheme(valGrad, "contrast", "Color")
    local valLabel = create("TextLabel", {
        Parent = valHolder, FontFace = customFont,
        Text = string.format("%.1f", default),
        TextColor3 = themes.preset.accent, BackgroundTransparency = 1,
        Size = dim2(1, 0, 1, 0), TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Center
    })
    applyTheme(valLabel, "accent", "TextColor3")

    -- Track: flat, 6px tall, outline border
    local trackOutline = create("Frame", {
        Parent = cardHolder, Position = dim2(0, 0, 0, 18),
        Size = dim2(1, 0, 0, 8),
        BackgroundColor3 = themes.preset.outline, BorderSizePixel = 0
    })
    applyTheme(trackOutline, "outline", "BackgroundColor3")

    local trackBg = create("Frame", {
        Parent = trackOutline, Position = dim2(0, 1, 0, 1),
        Size = dim2(1, -2, 1, -2), BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.high_contrast
    })
    applyTheme(trackBg, "high_contrast", "BackgroundColor3")

    local initRatio = math.clamp((default - min) / (max - min), 0, 1)
    local fill = create("Frame", {
        Parent = trackBg, Size = dim2(initRatio, 0, 1, 0),
        BackgroundColor3 = themes.preset.accent, BorderSizePixel = 0
    })
    applyTheme(fill, "accent", "BackgroundColor3")

    -- Grab handle: a small vertical bar that rides on the fill edge
    local handle = create("Frame", {
        Parent = trackBg,
        AnchorPoint = vec2(0.5, 0.5),
        Position = dim2(initRatio, 0, 0.5, 0),
        Size = dim2(0, 3, 1, 4),  -- slightly taller than track
        BackgroundColor3 = rgb(255, 255, 255),
        BorderSizePixel = 0, ZIndex = 3
    })

    local currentValue = default
    local dragging = false

    local function applyRatio(relX)
        relX = math.clamp(relX, 0, 1)
        currentValue = min + (max - min) * relX
        fill.Size           = dim2(relX, 0, 1, 0)
        handle.Position     = dim2(relX, 0, 0.5, 0)
        valLabel.Text       = string.format("%.1f", currentValue)
        if callback then callback(currentValue) end
    end

    -- InputBegan on the track starts drag
    trackOutline.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            local relX = (input.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X
            applyRatio(relX)
        end
    end)

    -- Global InputEnded stops drag (catches mouse-up outside track)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- Global InputChanged moves the fill while dragging
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local relX = (input.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X
            applyRatio(relX)
        end
    end)

    return cardOutline, function() return currentValue end
end

local function _makeKeybind(parent, label, defaultKey, callback, order)
