            ColorSequenceKeypoint.new(1,rgb(167,167,167)),
        }})
    create("UIListLayout",{ Parent=bottomComp, Padding=dim(0,10),
        SortOrder=Enum.SortOrder.LayoutOrder })

    local cur = default; local dragging = false
    local function round(v, interval) return math.floor(v/interval+0.5)*interval end
    local function setValueDirect(v)
        v = math.clamp(round(v,1), min, max)
        cur = v
        fill.Size = dim2((v-min)/(max-min), 0, 1, 0)
        sliderText.Text = tostring(v).."/"..tostring(max)
        safeCall(callback, v)
    end
    local function setValue(rawX)
        local ratio = math.clamp((rawX-sliderBtn.AbsolutePosition.X)/sliderBtn.AbsoluteSize.X, 0, 1)
        setValueDirect(min + (max-min)*ratio)
    end
    sliderBtn.MouseButton1Down:Connect(function() dragging=true end)
    conn(UserInputService.InputEnded, function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end)
    conn(UserInputService.InputChanged, function(inp)
        if dragging and inp.UserInputType==Enum.UserInputType.MouseMovement then
            setValue(inp.Position.X)
        end
    end)
    root.MouseEnter:Connect(function() tween(sliderHover,{BackgroundTransparency=0}) end)
    root.MouseLeave:Connect(function() tween(sliderHover,{BackgroundTransparency=1}) end)
    fill.Size = dim2((default-min)/(max-min), 0, 1, 0)
    sliderText.Text = tostring(default).."/"..tostring(max)

    local getter = function() return cur end
    local setter = function(v) setValueDirect(tonumber(v) or default) end
    return root, getter, setter
end

