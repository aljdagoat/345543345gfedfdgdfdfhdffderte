            Size=dim2(1,0,0,50), BorderSizePixel=0,
            BackgroundColor3=themes.preset.outline })
        applyTheme(eOut,"outline","BackgroundColor3")
        local eIn = create("Frame",{ Parent=eOut, Position=dim2(0,1,0,1),
            Size=dim2(1,-2,1,-2), BorderSizePixel=0,
            BackgroundColor3=themes.preset.inline })
        applyTheme(eIn,"inline","BackgroundColor3")
        local eH = create("Frame",{ Parent=eIn, Position=dim2(0,1,0,1),
            Size=dim2(1,-2,1,-2), BorderSizePixel=0, BackgroundColor3=rgb(255,255,255) })
        local eG = create("UIGradient",{ Parent=eH, Rotation=90,
            Color=ColorSequence.new{
                ColorSequenceKeypoint.new(0,themes.preset.low_contrast),
                ColorSequenceKeypoint.new(1,themes.preset.high_contrast),
            }})
        applyTheme(eG,"contrast","Color")
        local hov = create("Frame",{ Parent=eH, Size=dim2(1,0,1,0),
            BackgroundColor3=rgb(0,0,0), BackgroundTransparency=1,
            BorderSizePixel=0, ZIndex=2 })
        local aOut = create("Frame",{ Parent=eH, Position=dim2(0,5,0.5,-20),
            Size=dim2(0,40,0,40), BorderSizePixel=0,
            BackgroundColor3=themes.preset.outline, ZIndex=3 })
        applyTheme(aOut,"outline","BackgroundColor3")
        local aIn = create("Frame",{ Parent=aOut, Position=dim2(0,1,0,1),
            Size=dim2(1,-2,1,-2), BorderSizePixel=0,
            BackgroundColor3=themes.preset.inline, ZIndex=3 })
        applyTheme(aIn,"inline","BackgroundColor3")
        local avatar = create("ImageLabel",{ Parent=aIn, Position=dim2(0,1,0,1),
            Size=dim2(1,-2,1,-2), BackgroundTransparency=1,
            BorderSizePixel=0, BackgroundColor3=rgb(255,255,255), ZIndex=3 })
        task.spawn(function()
            local ok,img = pcall(function()
                return Players:GetUserThumbnailAsync(
                    player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size150x150)
            end)
            if ok then avatar.Image=img end
        end)
        create("TextLabel",{ Parent=eH, FontFace=customFont,
            TextColor3=themes.preset.text, Text=player.DisplayName,
            BackgroundTransparency=1, Position=dim2(0,50,0,8),
            Size=dim2(1,-55,0,14), BorderSizePixel=0,
            TextXAlignment=Enum.TextXAlignment.Left, TextSize=12,
            TextTruncate=Enum.TextTruncate.AtEnd,
            BackgroundColor3=rgb(255,255,255), ZIndex=3 })
        create("TextLabel",{ Parent=eH, FontFace=customFont,
            TextColor3=themes.preset.text, Text="@"..player.Name,
            BackgroundTransparency=1, Position=dim2(0,50,0,24),
            Size=dim2(1,-55,0,12), BorderSizePixel=0,
            TextXAlignment=Enum.TextXAlignment.Left, TextSize=10,
            TextTransparency=0.3, TextTruncate=Enum.TextTruncate.AtEnd,
            BackgroundColor3=rgb(255,255,255), ZIndex=3 })
        local clk = create("TextButton",{ Parent=eH, Size=dim2(1,0,1,0),
            BackgroundTransparency=1, Text="",
            BorderSizePixel=0, AutoButtonColor=false, ZIndex=4 })
        clk.MouseEnter:Connect(function() tween(hov,{BackgroundTransparency=0.7}) end)
        clk.MouseLeave:Connect(function() tween(hov,{BackgroundTransparency=1}) end)
        return eOut
    end

    local function refresh(term)
        term = (term or ""):lower()
        for _,c in ipairs(plc:GetChildren()) do
            if c:IsA("Frame") then c:Destroy() end
        end
        for _,p in ipairs(Players:GetPlayers()) do
            if term==""
                or p.DisplayName:lower():find(term,1,true)
                or p.Name:lower():find(term,1,true)
            then makeEntry(p) end
        end
    end

    refresh()
    searchBox:GetPropertyChangedSignal("Text"):Connect(function() refresh(searchBox.Text) end)
    conn(Players.PlayerAdded,    function() task.wait(0.5); refresh(searchBox.Text) end)
    conn(Players.PlayerRemoving, function() task.wait(0.1); refresh(searchBox.Text) end)

    return pc
end

